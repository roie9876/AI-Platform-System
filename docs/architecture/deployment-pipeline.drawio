<mxfile host="draw.io">
  <diagram name="Deployment Pipeline" id="deployment-pipeline">
    <mxGraphModel dx="1400" dy="700" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1400" pageHeight="700">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <!-- Title -->
        <mxCell id="title" value="Deployment Pipeline — scripts/deploy.sh" style="text;html=1;fontSize=18;fontStyle=1;align=center;verticalAlign=middle;fillColor=none;strokeColor=none;" vertex="1" parent="1">
          <mxGeometry x="300" y="15" width="800" height="30" as="geometry"/>
        </mxCell>

        <!-- ========== Phase 1: Infrastructure ========== -->
        <mxCell id="p1-box" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E3F2FD;strokeColor=#1565C0;strokeWidth=2;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="40" y="65" width="400" height="430" as="geometry"/>
        </mxCell>
        <mxCell id="p1-title" value="Phase 1: Infrastructure" style="text;html=1;fontSize=14;fontStyle=1;align=center;fillColor=#1565C0;strokeColor=none;fontColor=#fff;rounded=1;spacing=4;" vertex="1" parent="1">
          <mxGeometry x="100" y="75" width="280" height="28" as="geometry"/>
        </mxCell>

        <mxCell id="p1-cmd" value="az deployment group create" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#BBDEFB;strokeColor=#1565C0;fontSize=11;fontStyle=1;fontFamily=Courier New;" vertex="1" parent="1">
          <mxGeometry x="70" y="120" width="340" height="35" as="geometry"/>
        </mxCell>
        <mxCell id="p1-src" value="infra/main.bicep&lt;br&gt;(11 Bicep modules)" style="text;html=1;fontSize=10;fontStyle=2;align=center;fillColor=#FFF9C4;strokeColor=#F9A825;rounded=1;spacing=4;" vertex="1" parent="1">
          <mxGeometry x="140" y="170" width="200" height="30" as="geometry"/>
        </mxCell>

        <!-- Resources created -->
        <mxCell id="res-title" value="Creates:" style="text;html=1;fontSize=10;fontStyle=1;align=left;fillColor=none;strokeColor=none;fontColor=#1565C0;" vertex="1" parent="1">
          <mxGeometry x="70" y="215" width="60" height="16" as="geometry"/>
        </mxCell>

        <mxCell id="r1" value="VNet" style="image;aspect=fixed;html=1;points=[];image=img/lib/azure2/networking/Virtual_Networks.svg;labelPosition=right;verticalLabelPosition=middle;verticalAlign=middle;align=left;fontSize=9;" vertex="1" parent="1">
          <mxGeometry x="75" y="240" width="25" height="25" as="geometry"/>
        </mxCell>
        <mxCell id="r2" value="AKS" style="image;aspect=fixed;html=1;points=[];image=img/lib/azure2/containers/Kubernetes_Services.svg;labelPosition=right;verticalLabelPosition=middle;verticalAlign=middle;align=left;fontSize=9;" vertex="1" parent="1">
          <mxGeometry x="75" y="275" width="25" height="25" as="geometry"/>
        </mxCell>
        <mxCell id="r3" value="Cosmos DB" style="image;aspect=fixed;html=1;points=[];image=img/lib/azure2/databases/Azure_Cosmos_DB.svg;labelPosition=right;verticalLabelPosition=middle;verticalAlign=middle;align=left;fontSize=9;" vertex="1" parent="1">
          <mxGeometry x="75" y="310" width="25" height="25" as="geometry"/>
        </mxCell>
        <mxCell id="r4" value="ACR" style="image;aspect=fixed;html=1;points=[];image=img/lib/azure2/containers/Container_Registries.svg;labelPosition=right;verticalLabelPosition=middle;verticalAlign=middle;align=left;fontSize=9;" vertex="1" parent="1">
          <mxGeometry x="75" y="345" width="25" height="25" as="geometry"/>
        </mxCell>
        <mxCell id="r5" value="Key Vault" style="image;aspect=fixed;html=1;points=[];image=img/lib/azure2/security/Key_Vaults.svg;labelPosition=right;verticalLabelPosition=middle;verticalAlign=middle;align=left;fontSize=9;" vertex="1" parent="1">
          <mxGeometry x="220" y="240" width="25" height="25" as="geometry"/>
        </mxCell>
        <mxCell id="r6" value="App Insights" style="image;aspect=fixed;html=1;points=[];image=img/lib/azure2/devops/Application_Insights.svg;labelPosition=right;verticalLabelPosition=middle;verticalAlign=middle;align=left;fontSize=9;" vertex="1" parent="1">
          <mxGeometry x="220" y="275" width="25" height="25" as="geometry"/>
        </mxCell>
        <mxCell id="r7" value="Log Analytics" style="image;aspect=fixed;html=1;points=[];image=img/lib/azure2/management_governance/Log_Analytics_Workspaces.svg;labelPosition=right;verticalLabelPosition=middle;verticalAlign=middle;align=left;fontSize=9;" vertex="1" parent="1">
          <mxGeometry x="220" y="310" width="25" height="25" as="geometry"/>
        </mxCell>
        <mxCell id="r8" value="Identity" style="image;aspect=fixed;html=1;points=[];image=img/lib/azure2/identity/Managed_Identities.svg;labelPosition=right;verticalLabelPosition=middle;verticalAlign=middle;align=left;fontSize=9;" vertex="1" parent="1">
          <mxGeometry x="220" y="345" width="25" height="25" as="geometry"/>
        </mxCell>
        <mxCell id="r9" value="AGC" style="image;aspect=fixed;html=1;points=[];image=img/lib/azure2/networking/Application_Gateway_Containers.svg;labelPosition=right;verticalLabelPosition=middle;verticalAlign=middle;align=left;fontSize=9;" vertex="1" parent="1">
          <mxGeometry x="75" y="380" width="25" height="25" as="geometry"/>
        </mxCell>
        <mxCell id="r10" value="Alerts" style="image;aspect=fixed;html=1;points=[];image=img/lib/azure2/management_governance/Alerts.svg;labelPosition=right;verticalLabelPosition=middle;verticalAlign=middle;align=left;fontSize=9;" vertex="1" parent="1">
          <mxGeometry x="220" y="380" width="25" height="25" as="geometry"/>
        </mxCell>

        <mxCell id="skip-infra" value="--skip-infra" style="text;html=1;fontSize=9;fontStyle=3;align=center;fillColor=#FFCDD2;strokeColor=#C62828;rounded=1;spacing=3;" vertex="1" parent="1">
          <mxGeometry x="160" y="430" width="160" height="20" as="geometry"/>
        </mxCell>
        <mxCell id="skip-infra-note" value="Skip if infra already exists" style="text;html=1;fontSize=8;fontStyle=2;align=center;fillColor=none;strokeColor=none;" vertex="1" parent="1">
          <mxGeometry x="140" y="454" width="200" height="12" as="geometry"/>
        </mxCell>

        <!-- ========== Phase 2: Build & Push ========== -->
        <mxCell id="p2-box" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF3E0;strokeColor=#E65100;strokeWidth=2;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="500" y="65" width="380" height="430" as="geometry"/>
        </mxCell>
        <mxCell id="p2-title" value="Phase 2: Build &amp; Push" style="text;html=1;fontSize=14;fontStyle=1;align=center;fillColor=#E65100;strokeColor=none;fontColor=#fff;rounded=1;spacing=4;" vertex="1" parent="1">
          <mxGeometry x="560" y="75" width="260" height="28" as="geometry"/>
        </mxCell>

        <mxCell id="p2-cmd" value="docker build --platform linux/amd64" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFE0B2;strokeColor=#E65100;fontSize=10;fontStyle=1;fontFamily=Courier New;" vertex="1" parent="1">
          <mxGeometry x="520" y="120" width="340" height="35" as="geometry"/>
        </mxCell>
        <mxCell id="p2-push" value="docker push to ACR" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFE0B2;strokeColor=#E65100;fontSize=10;fontStyle=1;fontFamily=Courier New;" vertex="1" parent="1">
          <mxGeometry x="570" y="170" width="240" height="30" as="geometry"/>
        </mxCell>

        <!-- 6 images -->
        <mxCell id="img-title" value="6 Images (linux/amd64):" style="text;html=1;fontSize=10;fontStyle=1;align=left;fillColor=none;strokeColor=none;fontColor=#E65100;" vertex="1" parent="1">
          <mxGeometry x="530" y="215" width="180" height="16" as="geometry"/>
        </mxCell>
        <mxCell id="img1" value="api-gateway" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFCCBC;strokeColor=#BF360C;fontSize=9;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="530" y="240" width="100" height="28" as="geometry"/>
        </mxCell>
        <mxCell id="img2" value="agent-executor" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFCCBC;strokeColor=#BF360C;fontSize=9;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="645" y="240" width="110" height="28" as="geometry"/>
        </mxCell>
        <mxCell id="img3" value="tool-executor" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFCCBC;strokeColor=#BF360C;fontSize=9;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="770" y="240" width="100" height="28" as="geometry"/>
        </mxCell>
        <mxCell id="img4" value="mcp-proxy" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFCCBC;strokeColor=#BF360C;fontSize=9;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="530" y="280" width="100" height="28" as="geometry"/>
        </mxCell>
        <mxCell id="img5" value="workflow-engine" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFCCBC;strokeColor=#BF360C;fontSize=9;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="645" y="280" width="110" height="28" as="geometry"/>
        </mxCell>
        <mxCell id="img6" value="frontend" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFCCBC;strokeColor=#BF360C;fontSize=9;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="770" y="280" width="100" height="28" as="geometry"/>
        </mxCell>

        <!-- ACR target -->
        <mxCell id="acr-target" value="" style="image;aspect=fixed;html=1;points=[];image=img/lib/azure2/containers/Container_Registries.svg;" vertex="1" parent="1">
          <mxGeometry x="650" y="330" width="40" height="40" as="geometry"/>
        </mxCell>
        <mxCell id="acr-name" value="stumsftaiplatformprodacr.azurecr.io" style="text;html=1;fontSize=9;fontStyle=1;align=center;fillColor=none;strokeColor=none;fontColor=#E65100;" vertex="1" parent="1">
          <mxGeometry x="560" y="375" width="260" height="14" as="geometry"/>
        </mxCell>

        <mxCell id="skip-build" value="--skip-build" style="text;html=1;fontSize=9;fontStyle=3;align=center;fillColor=#FFCDD2;strokeColor=#C62828;rounded=1;spacing=3;" vertex="1" parent="1">
          <mxGeometry x="610" y="430" width="160" height="20" as="geometry"/>
        </mxCell>
        <mxCell id="skip-build-note" value="Skip if images unchanged" style="text;html=1;fontSize=8;fontStyle=2;align=center;fillColor=none;strokeColor=none;" vertex="1" parent="1">
          <mxGeometry x="590" y="454" width="200" height="12" as="geometry"/>
        </mxCell>

        <!-- ========== Phase 3: K8s Deploy ========== -->
        <mxCell id="p3-box" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E8F5E9;strokeColor=#2E7D32;strokeWidth=2;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="940" y="65" width="420" height="430" as="geometry"/>
        </mxCell>
        <mxCell id="p3-title" value="Phase 3: K8s Deploy" style="text;html=1;fontSize=14;fontStyle=1;align=center;fillColor=#2E7D32;strokeColor=none;fontColor=#fff;rounded=1;spacing=4;" vertex="1" parent="1">
          <mxGeometry x="1010" y="75" width="280" height="28" as="geometry"/>
        </mxCell>

        <mxCell id="p3-cmd" value="kustomize build | kubectl apply" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#C8E6C9;strokeColor=#2E7D32;fontSize=10;fontStyle=1;fontFamily=Courier New;" vertex="1" parent="1">
          <mxGeometry x="970" y="120" width="360" height="35" as="geometry"/>
        </mxCell>
        <mxCell id="p3-src" value="k8s/base/ + k8s/overlays/" style="text;html=1;fontSize=10;fontStyle=2;align=center;fillColor=#FFF9C4;strokeColor=#F9A825;rounded=1;spacing=4;" vertex="1" parent="1">
          <mxGeometry x="1050" y="170" width="200" height="25" as="geometry"/>
        </mxCell>

        <!-- Deploy steps -->
        <mxCell id="d1" value="1. Apply manifests&lt;br&gt;&lt;font style=&quot;font-size:8px&quot;&gt;Deployments, Services, HPA,&lt;br&gt;ConfigMap, Ingress&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DCEDC8;strokeColor=#33691E;fontSize=10;fontStyle=1;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="970" y="215" width="180" height="55" as="geometry"/>
        </mxCell>
        <mxCell id="d2" value="2. Rollout Status&lt;br&gt;&lt;font style=&quot;font-size:8px&quot;&gt;Wait for all pods Ready&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DCEDC8;strokeColor=#33691E;fontSize=10;fontStyle=1;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="970" y="285" width="180" height="45" as="geometry"/>
        </mxCell>
        <mxCell id="d3" value="3. Smoke Test&lt;br&gt;&lt;font style=&quot;font-size:8px&quot;&gt;/healthz checks on all pods&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DCEDC8;strokeColor=#33691E;fontSize=10;fontStyle=1;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="970" y="345" width="180" height="45" as="geometry"/>
        </mxCell>

        <!-- AKS target -->
        <mxCell id="aks-target" value="" style="image;aspect=fixed;html=1;points=[];image=img/lib/azure2/containers/Kubernetes_Services.svg;" vertex="1" parent="1">
          <mxGeometry x="1200" y="250" width="40" height="40" as="geometry"/>
        </mxCell>
        <mxCell id="aks-name" value="stumsft-aiplatform&lt;br&gt;-prod-aks" style="text;html=1;fontSize=9;fontStyle=1;align=center;fillColor=none;strokeColor=none;fontColor=#2E7D32;" vertex="1" parent="1">
          <mxGeometry x="1170" y="295" width="120" height="25" as="geometry"/>
        </mxCell>

        <mxCell id="dry-run" value="--dry-run" style="text;html=1;fontSize=9;fontStyle=3;align=center;fillColor=#FFCDD2;strokeColor=#C62828;rounded=1;spacing=3;" vertex="1" parent="1">
          <mxGeometry x="1070" y="430" width="100" height="20" as="geometry"/>
        </mxCell>
        <mxCell id="dry-run-note" value="Preview only" style="text;html=1;fontSize=8;fontStyle=2;align=center;fillColor=none;strokeColor=none;" vertex="1" parent="1">
          <mxGeometry x="1050" y="454" width="140" height="12" as="geometry"/>
        </mxCell>

        <!-- Phase arrows -->
        <mxCell id="ph12" value="" style="edgeStyle=orthogonalEdgeStyle;strokeWidth=3;strokeColor=#333;" edge="1" parent="1" source="p1-box" target="p2-box">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="ph23" value="" style="edgeStyle=orthogonalEdgeStyle;strokeWidth=3;strokeColor=#333;" edge="1" parent="1" source="p2-box" target="p3-box">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- CLI command -->
        <mxCell id="cli" value="./scripts/deploy.sh --resource-group &lt;rg&gt; --environment prod [--skip-infra] [--skip-build] [--dry-run]" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#333;strokeColor=#111;fontSize=11;fontStyle=1;fontColor=#0f0;fontFamily=Courier New;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="200" y="530" width="1000" height="35" as="geometry"/>
        </mxCell>

        <!-- Deploy steps arrows -->
        <mxCell id="dd12" value="" style="edgeStyle=orthogonalEdgeStyle;strokeWidth=1.5;strokeColor=#2E7D32;" edge="1" parent="1" source="d1" target="d2">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="dd23" value="" style="edgeStyle=orthogonalEdgeStyle;strokeWidth=1.5;strokeColor=#2E7D32;" edge="1" parent="1" source="d2" target="d3">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
