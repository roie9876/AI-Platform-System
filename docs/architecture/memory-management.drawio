<mxfile host="draw.io">
  <diagram name="Memory Management" id="memory-mgmt">
    <mxGraphModel dx="1200" dy="800" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1200" pageHeight="800">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <!-- Title -->
        <mxCell id="title" value="Memory Management — Short-Term &amp; Long-Term" style="text;html=1;fontSize=18;fontStyle=1;align=center;verticalAlign=middle;fillColor=none;strokeColor=none;" vertex="1" parent="1">
          <mxGeometry x="200" y="10" width="800" height="30" as="geometry"/>
        </mxCell>

        <!-- Outer Memory System box -->
        <mxCell id="mem-outer" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ECEFF1;strokeColor=#455A64;strokeWidth=3;" vertex="1" parent="1">
          <mxGeometry x="40" y="55" width="1120" height="390" as="geometry"/>
        </mxCell>
        <mxCell id="mem-label" value="MEMORY SYSTEM" style="text;html=1;fontSize=14;fontStyle=1;align=center;fillColor=none;strokeColor=none;fontColor=#455A64;" vertex="1" parent="1">
          <mxGeometry x="460" y="63" width="280" height="22" as="geometry"/>
        </mxCell>

        <!-- ========== SHORT-TERM MEMORY ========== -->
        <mxCell id="stm-box" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E3F2FD;strokeColor=#1565C0;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="70" y="100" width="500" height="320" as="geometry"/>
        </mxCell>
        <mxCell id="stm-label" value="SHORT-TERM MEMORY" style="text;html=1;fontSize=13;fontStyle=1;align=center;fillColor=none;strokeColor=none;fontColor=#1565C0;" vertex="1" parent="1">
          <mxGeometry x="190" y="108" width="260" height="20" as="geometry"/>
        </mxCell>
        <mxCell id="stm-sub" value="(Thread History)" style="text;html=1;fontSize=10;align=center;fillColor=none;strokeColor=none;fontColor=#666;" vertex="1" parent="1">
          <mxGeometry x="230" y="128" width="180" height="16" as="geometry"/>
        </mxCell>

        <!-- Thread visualization -->
        <mxCell id="thread-box" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#BBDEFB;strokeColor=#1565C0;strokeWidth=1;" vertex="1" parent="1">
          <mxGeometry x="100" y="155" width="440" height="180" as="geometry"/>
        </mxCell>
        <mxCell id="msg1" value="👤 User: &quot;Hello&quot;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#90CAF9;fontSize=10;align=left;spacingLeft=8;" vertex="1" parent="1">
          <mxGeometry x="120" y="165" width="400" height="28" as="geometry"/>
        </mxCell>
        <mxCell id="msg2" value="🤖 Assistant: &quot;Hi! How can I help?&quot;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E8F5E9;strokeColor=#A5D6A7;fontSize=10;align=left;spacingLeft=8;" vertex="1" parent="1">
          <mxGeometry x="120" y="198" width="400" height="28" as="geometry"/>
        </mxCell>
        <mxCell id="msg3" value="👤 User: &quot;Search for...&quot;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#90CAF9;fontSize=10;align=left;spacingLeft=8;" vertex="1" parent="1">
          <mxGeometry x="120" y="231" width="400" height="28" as="geometry"/>
        </mxCell>
        <mxCell id="msg4" value="🔧 Tool: {result}" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF3E0;strokeColor=#FFB74D;fontSize=10;align=left;spacingLeft=8;" vertex="1" parent="1">
          <mxGeometry x="120" y="264" width="400" height="28" as="geometry"/>
        </mxCell>
        <mxCell id="msg5" value="🤖 Assistant: &quot;I found...&quot;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E8F5E9;strokeColor=#A5D6A7;fontSize=10;align=left;spacingLeft=8;" vertex="1" parent="1">
          <mxGeometry x="120" y="297" width="400" height="28" as="geometry"/>
        </mxCell>

        <!-- STM properties -->
        <mxCell id="stm-props" value="Scope: per-thread&lt;br&gt;Storage: thread_messages (Cosmos)&lt;br&gt;Loaded: always (last N messages)&lt;br&gt;Lifetime: until thread deleted" style="text;html=1;fontSize=10;align=left;fillColor=#E8F5E9;strokeColor=#66BB6A;rounded=1;spacing=6;" vertex="1" parent="1">
          <mxGeometry x="100" y="348" width="220" height="60" as="geometry"/>
        </mxCell>

        <!-- ========== LONG-TERM MEMORY ========== -->
        <mxCell id="ltm-box" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF3E0;strokeColor=#E65100;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="600" y="100" width="530" height="320" as="geometry"/>
        </mxCell>
        <mxCell id="ltm-label" value="LONG-TERM MEMORY" style="text;html=1;fontSize=13;fontStyle=1;align=center;fillColor=none;strokeColor=none;fontColor=#E65100;" vertex="1" parent="1">
          <mxGeometry x="750" y="108" width="230" height="20" as="geometry"/>
        </mxCell>
        <mxCell id="ltm-sub" value="(Agent Memories)" style="text;html=1;fontSize=10;align=center;fillColor=none;strokeColor=none;fontColor=#666;" vertex="1" parent="1">
          <mxGeometry x="770" y="128" width="180" height="16" as="geometry"/>
        </mxCell>

        <!-- Memory entry visualization -->
        <mxCell id="mem-entry-box" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFE0B2;strokeColor=#E65100;strokeWidth=1;" vertex="1" parent="1">
          <mxGeometry x="630" y="155" width="470" height="180" as="geometry"/>
        </mxCell>

        <mxCell id="mem1" value="💡 &quot;User prefers concise answers&quot;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#FFB74D;fontSize=10;align=left;spacingLeft=8;" vertex="1" parent="1">
          <mxGeometry x="650" y="165" width="280" height="28" as="geometry"/>
        </mxCell>
        <mxCell id="mem1v" value="[0.23, -0.45, ...]" style="text;html=1;fontSize=8;align=center;fillColor=#F3E5F5;strokeColor=#CE93D8;rounded=1;" vertex="1" parent="1">
          <mxGeometry x="945" y="168" width="130" height="22" as="geometry"/>
        </mxCell>
        <mxCell id="mem2" value="💡 &quot;Project uses React + TypeScript&quot;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#FFB74D;fontSize=10;align=left;spacingLeft=8;" vertex="1" parent="1">
          <mxGeometry x="650" y="200" width="280" height="28" as="geometry"/>
        </mxCell>
        <mxCell id="mem2v" value="[0.67, 0.12, ...]" style="text;html=1;fontSize=8;align=center;fillColor=#F3E5F5;strokeColor=#CE93D8;rounded=1;" vertex="1" parent="1">
          <mxGeometry x="945" y="203" width="130" height="22" as="geometry"/>
        </mxCell>
        <mxCell id="mem3" value="💡 &quot;Team deadline is Q2 2026&quot;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#FFB74D;fontSize=10;align=left;spacingLeft=8;" vertex="1" parent="1">
          <mxGeometry x="650" y="235" width="280" height="28" as="geometry"/>
        </mxCell>
        <mxCell id="mem3v" value="[−0.11, 0.88, ...]" style="text;html=1;fontSize=8;align=center;fillColor=#F3E5F5;strokeColor=#CE93D8;rounded=1;" vertex="1" parent="1">
          <mxGeometry x="945" y="238" width="130" height="22" as="geometry"/>
        </mxCell>

        <mxCell id="embed-label" value="text-embedding-3-small&lt;br&gt;1536 dimensions" style="text;html=1;fontSize=9;align=center;fillColor=#F3E5F5;strokeColor=#CE93D8;rounded=1;fontStyle=1;spacing=4;" vertex="1" parent="1">
          <mxGeometry x="945" y="275" width="130" height="30" as="geometry"/>
        </mxCell>

        <mxCell id="extraction" value="Extracted via&lt;br&gt;extract_memories_from_thread" style="text;html=1;fontSize=9;align=center;fillColor=#E0F2F1;strokeColor=#4DB6AC;rounded=1;fontStyle=2;spacing=4;" vertex="1" parent="1">
          <mxGeometry x="650" y="280" width="200" height="30" as="geometry"/>
        </mxCell>

        <!-- LTM properties -->
        <mxCell id="ltm-props" value="Scope: per-agent, per-tenant&lt;br&gt;Storage: agent_memories (Cosmos)&lt;br&gt;Loaded: top-K by embedding similarity&lt;br&gt;Lifetime: persistent (cross-session)" style="text;html=1;fontSize=10;align=left;fillColor=#FBE9E7;strokeColor=#E65100;rounded=1;spacing=6;" vertex="1" parent="1">
          <mxGeometry x="630" y="348" width="240" height="60" as="geometry"/>
        </mxCell>

        <!-- ========== EXECUTION FLOW ========== -->
        <mxCell id="flow-box" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E8F5E9;strokeColor=#2E7D32;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="40" y="480" width="1120" height="140" as="geometry"/>
        </mxCell>
        <mxCell id="flow-label" value="Memory Flow at Execution Time" style="text;html=1;fontSize=13;fontStyle=1;align=center;fillColor=none;strokeColor=none;fontColor=#2E7D32;" vertex="1" parent="1">
          <mxGeometry x="380" y="488" width="440" height="20" as="geometry"/>
        </mxCell>

        <mxCell id="f1" value="1. User sends&lt;br&gt;message" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#C8E6C9;strokeColor=#2E7D32;fontSize=10;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="70" y="525" width="120" height="50" as="geometry"/>
        </mxCell>
        <mxCell id="f2" value="2. Load STM&lt;br&gt;last N messages&lt;br&gt;from thread" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#BBDEFB;strokeColor=#1565C0;fontSize=10;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="240" y="525" width="140" height="50" as="geometry"/>
        </mxCell>
        <mxCell id="f3" value="3. Load LTM&lt;br&gt;top-K memories&lt;br&gt;by similarity" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFE0B2;strokeColor=#E65100;fontSize=10;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="430" y="525" width="140" height="50" as="geometry"/>
        </mxCell>
        <mxCell id="f4" value="4. Inject both&lt;br&gt;into system&lt;br&gt;prompt context" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E1BEE7;strokeColor=#6A1B9A;fontSize=10;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="620" y="525" width="140" height="50" as="geometry"/>
        </mxCell>
        <mxCell id="f5" value="5. Send to&lt;br&gt;LLM" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#C8E6C9;strokeColor=#2E7D32;fontSize=10;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="810" y="525" width="120" height="50" as="geometry"/>
        </mxCell>

        <mxCell id="f12" value="" style="edgeStyle=orthogonalEdgeStyle;strokeWidth=2;strokeColor=#2E7D32;" edge="1" parent="1" source="f1" target="f2">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="f23" value="" style="edgeStyle=orthogonalEdgeStyle;strokeWidth=2;strokeColor=#2E7D32;" edge="1" parent="1" source="f2" target="f3">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="f34" value="" style="edgeStyle=orthogonalEdgeStyle;strokeWidth=2;strokeColor=#2E7D32;" edge="1" parent="1" source="f3" target="f4">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="f45" value="" style="edgeStyle=orthogonalEdgeStyle;strokeWidth=2;strokeColor=#2E7D32;" edge="1" parent="1" source="f4" target="f5">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Isolation note -->
        <mxCell id="isolation" value="Agent A's memories are NEVER injected into Agent B's context" style="text;html=1;fontSize=10;align=center;fillColor=#FFCDD2;strokeColor=#C62828;rounded=1;fontStyle=3;spacing=6;" vertex="1" parent="1">
          <mxGeometry x="310" y="590" width="380" height="24" as="geometry"/>
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
