        <mxCell id="tlimit" value="LimitRange&lt;br&gt;&lt;font style=&quot;font-size:8px&quot;&gt;250m / 512Mi max&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFCCBC;strokeColor=#BF360C;fontSize=9;" vertex="1" parent="1">
