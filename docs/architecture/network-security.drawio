        <mxCell id="isolation-note" value="Tenant Isolation: deny-all default + explicit allow from aiplatform namespace" style="text;html=1;fontSize=9;fontStyle=2;align=left;fillColor=none;strokeColor=none;fontColor=#E65100;" vertex="1" parent="1">
          <mxGeometry x="110" y="580" width="450" height="14" as="geometry"/>
        </mxCell>
        <mxCell id="replicate-note" value="← Replicated per tenant (one namespace per tenant)" style="text;html=1;fontSize=9;fontStyle=1;align=left;fillColor=none;strokeColor=none;fontColor=#BF360C;" vertex="1" parent="1">
