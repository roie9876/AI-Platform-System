        <!-- NetworkPolicy note for shared -->
        <mxCell id="netpol-shared" value="NetworkPolicy: allow 8000/3000 from AGC only" style="text;html=1;fontSize=9;fontStyle=2;align=left;fillColor=none;strokeColor=none;fontColor=#2E7D32;" vertex="1" parent="1">
