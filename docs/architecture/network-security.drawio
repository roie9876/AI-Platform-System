        <mxCell id="aks-subnet-label" value="AKS Nodes Subnet — 10.0.0.0/22" style="text;html=1;fontSize=11;fontStyle=1;align=left;fillColor=none;strokeColor=none;fontColor=#1565C0;" vertex="1" parent="1">
          <mxGeometry x="75" y="128" width="300" height="18" as="geometry"/>
