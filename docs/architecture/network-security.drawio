<mxfile host="draw.io">
  <diagram name="Network Security Boundaries" id="network-security">
    <mxGraphModel dx="1400" dy="900" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1400" pageHeight="900">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <!-- Title -->
        <mxCell id="title" value="Network Security Boundaries" style="text;html=1;fontSize=18;fontStyle=1;align=center;verticalAlign=middle;fillColor=none;strokeColor=none;" vertex="1" parent="1">
          <mxGeometry x="400" y="10" width="600" height="30" as="geometry"/>
        </mxCell>

        <!-- VNet outer box -->
        <mxCell id="vnet" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E8EAF6;strokeColor=#283593;strokeWidth=3;dashed=0;" vertex="1" parent="1">
          <mxGeometry x="40" y="55" width="1320" height="810" as="geometry"/>
        </mxCell>
        <mxCell id="vnet-icon" value="Azure VNet" style="image;aspect=fixed;html=1;points=[];align=center;image=img/lib/azure2/networking/Virtual_Networks.svg;labelPosition=center;verticalLabelPosition=bottom;verticalAlign=top;fontSize=11;fontStyle=1;fontColor=#283593;" vertex="1" parent="1">
          <mxGeometry x="60" y="65" width="40" height="40" as="geometry"/>
        </mxCell>
        <mxCell id="vnet-cidr" value="10.0.0.0/16" style="text;html=1;fontSize=11;fontStyle=1;align=left;fillColor=none;strokeColor=none;fontColor=#283593;" vertex="1" parent="1">
          <mxGeometry x="110" y="75" width="120" height="20" as="geometry"/>
        </mxCell>

