<mxfile host="draw.io">
  <diagram name="Observability Stack" id="observability">
    <mxGraphModel dx="1400" dy="900" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1400" pageHeight="900">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <!-- Title -->
        <mxCell id="title" value="Observability Architecture" style="text;html=1;fontSize=18;fontStyle=1;align=center;verticalAlign=middle;fillColor=none;strokeColor=none;" vertex="1" parent="1">
          <mxGeometry x="400" y="10" width="600" height="30" as="geometry"/>
        </mxCell>

        <!-- ========== Per-Pod Instrumentation (top) ========== -->
        <mxCell id="pod-zone" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E3F2FD;strokeColor=#1565C0;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="40" y="55" width="1320" height="240" as="geometry"/>
        </mxCell>
        <mxCell id="pod-zone-label" value="PER-POD INSTRUMENTATION (all 5 backend microservices)" style="text;html=1;fontSize=12;fontStyle=1;align=left;fillColor=none;strokeColor=none;fontColor=#1565C0;" vertex="1" parent="1">
          <mxGeometry x="55" y="63" width="500" height="18" as="geometry"/>
        </mxCell>

        <!-- Instrumentation cards -->
        <mxCell id="inst1" value="FastAPI&lt;br&gt;Instrumentation&lt;br&gt;&lt;font style=&quot;font-size:8px&quot;&gt;Request spans (method, path)&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#BBDEFB;strokeColor=#1565C0;fontSize=10;fontStyle=1;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="60" y="95" width="160" height="55" as="geometry"/>
        </mxCell>
        <mxCell id="inst2" value="HTTPX&lt;br&gt;Instrumentation&lt;br&gt;&lt;font style=&quot;font-size:8px&quot;&gt;Inter-service call spans&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#BBDEFB;strokeColor=#1565C0;fontSize=10;fontStyle=1;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="240" y="95" width="160" height="55" as="geometry"/>
        </mxCell>
        <mxCell id="inst3" value="Custom Spans&lt;br&gt;&lt;font style=&quot;font-size:8px&quot;&gt;LLM calls, tool execution,&lt;br&gt;RAG retrieval&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#BBDEFB;strokeColor=#1565C0;fontSize=10;fontStyle=1;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="420" y="95" width="160" height="55" as="geometry"/>
        </mxCell>
        <mxCell id="inst4" value="Structured Logger&lt;br&gt;&lt;font style=&quot;font-size:8px&quot;&gt;JSON logs with&lt;br&gt;trace_id, span_id&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#BBDEFB;strokeColor=#1565C0;fontSize=10;fontStyle=1;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="600" y="95" width="160" height="55" as="geometry"/>
        </mxCell>

        <!-- OpenTelemetry SDK -->
        <mxCell id="otel" value="OpenTelemetry SDK" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#C5CAE9;strokeColor=#283593;fontSize=13;fontStyle=1;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="200" y="175" width="560" height="40" as="geometry"/>
        </mxCell>

        <!-- Azure Monitor Exporter -->
        <mxCell id="exporter" value="Azure Monitor Exporter" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#9FA8DA;strokeColor=#283593;fontSize=11;fontStyle=1;shadow=1;fontColor=#fff;" vertex="1" parent="1">
          <mxGeometry x="300" y="235" width="360" height="35" as="geometry"/>
        </mxCell>

        <!-- Arrows from instrumentation to OTel -->
        <mxCell id="i1" value="" style="edgeStyle=orthogonalEdgeStyle;strokeWidth=1.5;strokeColor=#1565C0;" edge="1" parent="1" source="inst1" target="otel">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="i2" value="" style="edgeStyle=orthogonalEdgeStyle;strokeWidth=1.5;strokeColor=#1565C0;" edge="1" parent="1" source="inst2" target="otel">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="i3" value="" style="edgeStyle=orthogonalEdgeStyle;strokeWidth=1.5;strokeColor=#1565C0;" edge="1" parent="1" source="inst3" target="otel">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="i4" value="" style="edgeStyle=orthogonalEdgeStyle;strokeWidth=1.5;strokeColor=#1565C0;" edge="1" parent="1" source="inst4" target="otel">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="i5" value="" style="edgeStyle=orthogonalEdgeStyle;strokeWidth=1.5;strokeColor=#283593;" edge="1" parent="1" source="otel" target="exporter">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Metrics table on the right side of pod zone -->
        <mxCell id="metrics-box" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E8EAF6;strokeColor=#283593;strokeWidth=1;" vertex="1" parent="1">
          <mxGeometry x="830" y="90" width="510" height="190" as="geometry"/>
        </mxCell>
        <mxCell id="metrics-title" value="What Gets Tracked Per Execution" style="text;html=1;fontSize=11;fontStyle=1;align=center;fillColor=none;strokeColor=none;fontColor=#283593;" vertex="1" parent="1">
          <mxGeometry x="930" y="97" width="310" height="16" as="geometry"/>
        </mxCell>
        <mxCell id="m1" value="Input tokens ← LLM usage → execution_logs" style="text;html=1;fontSize=9;align=left;fillColor=none;strokeColor=none;" vertex="1" parent="1">
          <mxGeometry x="850" y="118" width="280" height="14" as="geometry"/>
        </mxCell>
        <mxCell id="m2" value="Output tokens ← LLM usage → execution_logs" style="text;html=1;fontSize=9;align=left;fillColor=none;strokeColor=none;" vertex="1" parent="1">
          <mxGeometry x="850" y="136" width="280" height="14" as="geometry"/>
        </mxCell>
        <mxCell id="m3" value="Total cost ($) ← token × pricing → execution_logs" style="text;html=1;fontSize=9;align=left;fillColor=none;strokeColor=none;" vertex="1" parent="1">
          <mxGeometry x="850" y="154" width="280" height="14" as="geometry"/>
        </mxCell>
        <mxCell id="m4" value="Latency (ms) ← middleware timing → App Insights" style="text;html=1;fontSize=9;align=left;fillColor=none;strokeColor=none;" vertex="1" parent="1">
          <mxGeometry x="850" y="172" width="280" height="14" as="geometry"/>
        </mxCell>
        <mxCell id="m5" value="Tool calls count ← ReAct loop → execution_logs" style="text;html=1;fontSize=9;align=left;fillColor=none;strokeColor=none;" vertex="1" parent="1">
          <mxGeometry x="850" y="190" width="280" height="14" as="geometry"/>
        </mxCell>
        <mxCell id="m6" value="Error rate ← exception spans → App Insights" style="text;html=1;fontSize=9;align=left;fillColor=none;strokeColor=none;" vertex="1" parent="1">
          <mxGeometry x="850" y="208" width="280" height="14" as="geometry"/>
        </mxCell>
        <mxCell id="m7" value="Trace ID ← OTel propagation → all logs" style="text;html=1;fontSize=9;align=left;fillColor=none;strokeColor=none;" vertex="1" parent="1">
          <mxGeometry x="850" y="226" width="280" height="14" as="geometry"/>
        </mxCell>

        <!-- ========== Azure Observability Stack (middle) ========== -->
        <mxCell id="azure-zone" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF3E0;strokeColor=#E65100;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="40" y="330" width="1320" height="250" as="geometry"/>
        </mxCell>
        <mxCell id="azure-zone-label" value="AZURE OBSERVABILITY STACK" style="text;html=1;fontSize=12;fontStyle=1;align=left;fillColor=none;strokeColor=none;fontColor=#E65100;" vertex="1" parent="1">
          <mxGeometry x="55" y="338" width="300" height="18" as="geometry"/>
        </mxCell>

        <!-- App Insights -->
        <mxCell id="ai" value="Application&lt;br&gt;Insights" style="image;aspect=fixed;html=1;points=[];align=center;image=img/lib/azure2/devops/Application_Insights.svg;labelPosition=center;verticalLabelPosition=bottom;verticalAlign=top;fontSize=10;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="100" y="370" width="50" height="50" as="geometry"/>
        </mxCell>
        <mxCell id="ai-info" value="APM&lt;br&gt;Dependency map&lt;br&gt;Exception tracking&lt;br&gt;Live metrics" style="text;html=1;fontSize=9;align=left;fillColor=#FFE0B2;strokeColor=#E65100;rounded=1;spacing=4;" vertex="1" parent="1">
          <mxGeometry x="60" y="440" width="130" height="55" as="geometry"/>
        </mxCell>

        <!-- Log Analytics -->
        <mxCell id="la" value="Log Analytics" style="image;aspect=fixed;html=1;points=[];align=center;image=img/lib/azure2/management_governance/Log_Analytics_Workspaces.svg;labelPosition=center;verticalLabelPosition=bottom;verticalAlign=top;fontSize=10;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="320" y="370" width="50" height="50" as="geometry"/>
        </mxCell>
        <mxCell id="la-info" value="KQL queries&lt;br&gt;30-day retention&lt;br&gt;Diagnostic logs" style="text;html=1;fontSize=9;align=left;fillColor=#FFE0B2;strokeColor=#E65100;rounded=1;spacing=4;" vertex="1" parent="1">
          <mxGeometry x="280" y="440" width="130" height="45" as="geometry"/>
        </mxCell>

        <!-- Alerts -->
        <mxCell id="alerts" value="Monitor&lt;br&gt;Alerts" style="image;aspect=fixed;html=1;points=[];align=center;image=img/lib/azure2/management_governance/Alerts.svg;labelPosition=center;verticalLabelPosition=bottom;verticalAlign=top;fontSize=10;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="530" y="370" width="50" height="50" as="geometry"/>
        </mxCell>
        <mxCell id="alerts-info" value="Pod restart &gt; 5 in 5min&lt;br&gt;→ email notification&lt;br&gt;Metric thresholds" style="text;html=1;fontSize=9;align=left;fillColor=#FFE0B2;strokeColor=#E65100;rounded=1;spacing=4;" vertex="1" parent="1">
          <mxGeometry x="490" y="440" width="140" height="45" as="geometry"/>
        </mxCell>

        <!-- Cost Dashboard -->
        <mxCell id="cost-box" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E8F5E9;strokeColor=#2E7D32;strokeWidth=2;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="720" y="360" width="600" height="200" as="geometry"/>
        </mxCell>
        <mxCell id="cost-title" value="Platform Cost Dashboard — /api/v1/observability/*" style="text;html=1;fontSize=11;fontStyle=1;align=center;fillColor=none;strokeColor=none;fontColor=#2E7D32;" vertex="1" parent="1">
          <mxGeometry x="780" y="368" width="480" height="18" as="geometry"/>
        </mxCell>

        <mxCell id="kpi1" value="KPI Tiles&lt;br&gt;&lt;font style=&quot;font-size:8px&quot;&gt;requests, tokens,&lt;br&gt;cost, latency&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#C8E6C9;strokeColor=#2E7D32;fontSize=9;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="740" y="395" width="110" height="50" as="geometry"/>
        </mxCell>
        <mxCell id="kpi2" value="Token Usage&lt;br&gt;Charts&lt;br&gt;&lt;font style=&quot;font-size:8px&quot;&gt;time-series&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#C8E6C9;strokeColor=#2E7D32;fontSize=9;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="860" y="395" width="110" height="50" as="geometry"/>
        </mxCell>
        <mxCell id="kpi3" value="Cost Breakdown&lt;br&gt;&lt;font style=&quot;font-size:8px&quot;&gt;by agent / model&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#C8E6C9;strokeColor=#2E7D32;fontSize=9;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="980" y="395" width="110" height="50" as="geometry"/>
        </mxCell>
        <mxCell id="kpi4" value="Execution Logs&lt;br&gt;&lt;font style=&quot;font-size:8px&quot;&gt;state snapshots&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#C8E6C9;strokeColor=#2E7D32;fontSize=9;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="1100" y="395" width="110" height="50" as="geometry"/>
        </mxCell>

        <!-- Budget Alerts -->
        <mxCell id="budget" value="Budget Alerts" style="image;aspect=fixed;html=1;points=[];align=center;image=img/lib/azure2/general/Cost_Alerts.svg;labelPosition=center;verticalLabelPosition=bottom;verticalAlign=top;fontSize=9;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="780" y="470" width="40" height="40" as="geometry"/>
        </mxCell>
        <mxCell id="budget-info" value="Threshold alerts + spike detection" style="text;html=1;fontSize=9;align=left;fillColor=none;strokeColor=none;" vertex="1" parent="1">
          <mxGeometry x="840" y="480" width="230" height="14" as="geometry"/>
        </mxCell>

        <!-- Arrows from exporter to Azure stack -->
        <mxCell id="e1" value="" style="edgeStyle=orthogonalEdgeStyle;strokeWidth=2;strokeColor=#283593;" edge="1" parent="1" source="exporter" target="ai">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="e2" value="" style="edgeStyle=orthogonalEdgeStyle;strokeWidth=2;strokeColor=#283593;" edge="1" parent="1" source="exporter" target="la">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <!-- AI → Alerts -->
        <mxCell id="e3" value="" style="edgeStyle=orthogonalEdgeStyle;strokeWidth=1.5;strokeColor=#E65100;" edge="1" parent="1" source="ai" target="alerts">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- ========== Data Store ========== -->
        <mxCell id="cosmos-note" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F5F5F5;strokeColor=#999;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="40" y="610" width="440" height="100" as="geometry"/>
        </mxCell>
        <mxCell id="cosmos-icon" value="Cosmos DB" style="image;aspect=fixed;html=1;points=[];align=center;image=img/lib/azure2/databases/Azure_Cosmos_DB.svg;labelPosition=center;verticalLabelPosition=bottom;verticalAlign=top;fontSize=10;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="60" y="625" width="40" height="40" as="geometry"/>
        </mxCell>
        <mxCell id="cosmos-info" value="execution_logs container&lt;br&gt;• tokens, cost, latency per execution&lt;br&gt;• partition key: /tenant_id&lt;br&gt;• queried by Cost Dashboard" style="text;html=1;fontSize=9;align=left;fillColor=none;strokeColor=none;" vertex="1" parent="1">
          <mxGeometry x="115" y="625" width="340" height="55" as="geometry"/>
        </mxCell>

        <!-- Correlation note -->
        <mxCell id="corr" value="End-to-End Correlation: OpenTelemetry trace_id propagated across all pods • Visible in App Insights dependency map" style="text;html=1;fontSize=10;align=center;fillColor=#F5F5F5;strokeColor=#999;rounded=1;spacing=6;" vertex="1" parent="1">
          <mxGeometry x="200" y="740" width="1000" height="24" as="geometry"/>
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
