        <mxCell id="ae-model" value="Model Abstraction" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFE0B2;strokeColor=#E65100;fontSize=10;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="580" y="238" width="190" height="30" as="geometry"/>
