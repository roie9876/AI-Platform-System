        <!-- Tool Executor Pod -->
        <mxCell id="te-pod" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#E65100;strokeWidth=2;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="820" y="120" width="230" height="290" as="geometry"/>
        </mxCell>
        <mxCell id="te-title" value="Tool Executor Pod" style="text;html=1;fontSize=12;fontStyle=1;align=center;fillColor=none;strokeColor=none;fontColor=#E65100;" vertex="1" parent="1">
