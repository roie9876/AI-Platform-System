          <mxGeometry x="970" y="490" width="100" height="30" as="geometry"/>
        </mxCell>
        <mxCell id="wf-sub" value="Sub-Agent Delegation" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFE0B2;strokeColor=#E65100;fontSize=10;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="1090" y="490" width="140" height="30" as="geometry"/>
        </mxCell>

        <!-- Runtime Plane characteristics -->
        <mxCell id="rp-chars" value="High frequency (user conversations)&lt;br&gt;Stateful • KEDA 0→N replicas&lt;br&gt;Milliseconds latency critical (streaming)&lt;br&gt;&lt;i&gt;If down: &quot;Agents don't respond&quot;&lt;/i&gt;" style="text;html=1;fontSize=10;align=center;fillColor=#FBE9E7;strokeColor=#E65100;rounded=1;spacing=6;" vertex="1" parent="1">
          <mxGeometry x="770" y="640" width="290" height="60" as="geometry"/>
        </mxCell>

        <!-- Inter-pod edges inside runtime plane -->
        <mxCell id="ae-te-edge" value="tool exec" style="edgeStyle=orthogonalEdgeStyle;strokeWidth=1.5;strokeColor=#E65100;fontSize=9;fontColor=#E65100;dashed=1;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;" edge="1" parent="1" source="ae-pod" target="te-pod">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="ae-mcp-edge" value="MCP calls" style="edgeStyle=orthogonalEdgeStyle;strokeWidth=1.5;strokeColor=#E65100;fontSize=9;fontColor=#E65100;dashed=1;exitX=1;exitY=0.3;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;" edge="1" parent="1" source="te-pod" target="mcp-pod">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="wf-ae-edge" value="internal/execute" style="edgeStyle=orthogonalEdgeStyle;strokeWidth=1.5;strokeColor=#E65100;fontSize=9;fontColor=#E65100;dashed=1;exitX=0;exitY=0.5;exitDx=0;exitDy=0;entryX=0.5;entryY=1;entryDx=0;entryDy=0;" edge="1" parent="1" source="wf-pod" target="ae-pod">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Legend -->
        <mxCell id="legend-box" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#333333;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="40" y="590" width="350" height="140" as="geometry"/>
        </mxCell>
        <mxCell id="legend-title" value="Architecture Summary" style="text;html=1;fontSize=11;fontStyle=1;align=left;fillColor=none;strokeColor=none;" vertex="1" parent="1">
          <mxGeometry x="55" y="598" width="200" height="18" as="geometry"/>
        </mxCell>
        <mxCell id="legend-1" value="• Control Plane can go down without affecting running agents" style="text;html=1;fontSize=10;align=left;fillColor=none;strokeColor=none;" vertex="1" parent="1">
          <mxGeometry x="55" y="620" width="330" height="16" as="geometry"/>
        </mxCell>
        <mxCell id="legend-2" value="• Runtime Plane scales independently for execution load" style="text;html=1;fontSize=10;align=left;fillColor=none;strokeColor=none;" vertex="1" parent="1">
          <mxGeometry x="55" y="640" width="330" height="16" as="geometry"/>
        </mxCell>
        <mxCell id="legend-3" value="• Configs flow from Control → Runtime (orange arrow)" style="text;html=1;fontSize=10;align=left;fillColor=none;strokeColor=none;" vertex="1" parent="1">
          <mxGeometry x="55" y="660" width="330" height="16" as="geometry"/>
        </mxCell>
        <mxCell id="legend-4" value="• All pods share the same Python app/ codebase" style="text;html=1;fontSize=10;align=left;fillColor=none;strokeColor=none;" vertex="1" parent="1">
          <mxGeometry x="55" y="680" width="330" height="16" as="geometry"/>
        </mxCell>
        <mxCell id="legend-5" value="• Dashed edges = inter-service HTTP calls" style="text;html=1;fontSize=10;align=left;fillColor=none;strokeColor=none;" vertex="1" parent="1">
          <mxGeometry x="55" y="700" width="330" height="16" as="geometry"/>
        </mxCell>

