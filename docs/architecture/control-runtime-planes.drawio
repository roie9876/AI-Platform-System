        <mxCell id="mcp-discovery" value="Server Discovery" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFE0B2;strokeColor=#E65100;fontSize=10;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="1100" y="158" width="110" height="30" as="geometry"/>
        </mxCell>
        <mxCell id="mcp-bridge" value="Protocol Bridge" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFE0B2;strokeColor=#E65100;fontSize=10;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="1220" y="158" width="95" height="30" as="geometry"/>
        </mxCell>
        <mxCell id="mcp-call" value="Tool Call Proxy" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFE0B2;strokeColor=#E65100;fontSize=10;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="1100" y="198" width="215" height="30" as="geometry"/>
        </mxCell>

        <!-- Workflow Engine Pod -->
        <mxCell id="wf-pod" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#E65100;strokeWidth=2;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="660" y="450" width="600" height="160" as="geometry"/>
        </mxCell>
        <mxCell id="wf-title" value="Workflow Engine Pod" style="text;html=1;fontSize=12;fontStyle=1;align=center;fillColor=none;strokeColor=none;fontColor=#E65100;" vertex="1" parent="1">
