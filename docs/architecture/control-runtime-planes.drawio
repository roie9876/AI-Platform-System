        <mxCell id="rp-ns" value="Namespace: tenant-{slug}" style="text;html=1;fontSize=10;align=center;fillColor=none;strokeColor=none;fontColor=#666666;" vertex="1" parent="1">
          <mxGeometry x="830" y="88" width="220" height="16" as="geometry"/>
        </mxCell>

        <!-- Agent Executor Pod -->
        <mxCell id="ae-pod" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#E65100;strokeWidth=2;shadow=1;" vertex="1" parent="1">
