        <mxCell id="te-knowledge" value="Knowledge / AI Search" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFE0B2;strokeColor=#E65100;fontSize=10;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="840" y="238" width="190" height="30" as="geometry"/>
        </mxCell>

        <!-- MCP Proxy Pod -->
        <mxCell id="mcp-pod" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#E65100;strokeWidth=2;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="1080" y="120" width="250" height="290" as="geometry"/>
        </mxCell>
