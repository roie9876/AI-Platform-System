<mxfile host="draw.io">
  <diagram name="Control Plane vs Runtime Plane" id="ctrl-runtime">
    <mxGraphModel dx="1400" dy="900" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1400" pageHeight="900">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <!-- Title -->
        <mxCell id="title" value="Control Plane vs Runtime Plane" style="text;html=1;fontSize=18;fontStyle=1;align=center;verticalAlign=middle;fillColor=none;strokeColor=none;" vertex="1" parent="1">
          <mxGeometry x="350" y="10" width="700" height="30" as="geometry"/>
        </mxCell>

        <!-- ==================== CONTROL PLANE ==================== -->
        <mxCell id="cp-zone" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E3F2FD;strokeColor=#1565C0;strokeWidth=3;verticalAlign=top;fontSize=14;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="40" y="60" width="380" height="500" as="geometry"/>
        </mxCell>
        <mxCell id="cp-label" value="CONTROL PLANE" style="text;html=1;fontSize=14;fontStyle=1;align=center;fillColor=none;strokeColor=none;fontColor=#1565C0;" vertex="1" parent="1">
          <mxGeometry x="120" y="68" width="220" height="22" as="geometry"/>
        </mxCell>
        <mxCell id="cp-ns" value="Namespace: aiplatform" style="text;html=1;fontSize=10;align=center;fillColor=none;strokeColor=none;fontColor=#666666;" vertex="1" parent="1">
          <mxGeometry x="120" y="88" width="220" height="16" as="geometry"/>
        </mxCell>

        <!-- API Gateway Pod -->
        <mxCell id="gw-pod" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#1565C0;strokeWidth=2;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="70" y="120" width="320" height="420" as="geometry"/>
        </mxCell>
        <mxCell id="gw-title" value="API Gateway Pod" style="text;html=1;fontSize=13;fontStyle=1;align=center;fillColor=none;strokeColor=none;fontColor=#1565C0;" vertex="1" parent="1">
          <mxGeometry x="140" y="128" width="180" height="20" as="geometry"/>
        </mxCell>
        <mxCell id="gw-port" value=":8000" style="text;html=1;fontSize=9;align=center;fillColor=none;strokeColor=none;fontColor=#999;" vertex="1" parent="1">
          <mxGeometry x="320" y="128" width="50" height="16" as="geometry"/>
        </mxCell>

        <!-- Control Plane modules -->
        <mxCell id="auth" value="Auth &amp; RBAC" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#BBDEFB;strokeColor=#1565C0;fontSize=11;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="90" y="160" width="130" height="36" as="geometry"/>
        </mxCell>
        <mxCell id="tenant" value="Tenant Manager" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#BBDEFB;strokeColor=#1565C0;fontSize=11;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="240" y="160" width="130" height="36" as="geometry"/>
        </mxCell>
        <mxCell id="registry" value="Agent Registry" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#BBDEFB;strokeColor=#1565C0;fontSize=11;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="90" y="210" width="130" height="36" as="geometry"/>
        </mxCell>
        <mxCell id="policy" value="Policy Engine" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#BBDEFB;strokeColor=#1565C0;fontSize=11;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="240" y="210" width="130" height="36" as="geometry"/>
        </mxCell>
        <mxCell id="marketplace" value="Marketplace" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#BBDEFB;strokeColor=#1565C0;fontSize=11;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="90" y="260" width="130" height="36" as="geometry"/>
        </mxCell>
        <mxCell id="eval" value="Eval Engine" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#BBDEFB;strokeColor=#1565C0;fontSize=11;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="240" y="260" width="130" height="36" as="geometry"/>
        </mxCell>
        <mxCell id="models" value="Model Endpoints" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#BBDEFB;strokeColor=#1565C0;fontSize=11;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="90" y="310" width="130" height="36" as="geometry"/>
        </mxCell>
        <mxCell id="cost" value="Cost Dashboard" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#BBDEFB;strokeColor=#1565C0;fontSize=11;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="240" y="310" width="130" height="36" as="geometry"/>
        </mxCell>

        <!-- Control Plane characteristics -->
        <mxCell id="cp-chars" value="Low frequency (admin CRUD)&lt;br&gt;Stateless • 1–2 replicas&lt;br&gt;Seconds latency OK&lt;br&gt;&lt;i&gt;If down: &quot;Can't manage agents&quot;&lt;/i&gt;" style="text;html=1;fontSize=10;align=center;fillColor=#E8F5E9;strokeColor=#66BB6A;rounded=1;spacing=6;" vertex="1" parent="1">
          <mxGeometry x="100" y="370" width="260" height="60" as="geometry"/>
        </mxCell>

        <!-- Arrow: Configs & Policies -->
        <mxCell id="cp-rp-edge" value="Configs &amp; Policies" style="edgeStyle=orthogonalEdgeStyle;strokeWidth=2;strokeColor=#FF6F00;fontColor=#FF6F00;fontSize=10;fontStyle=1;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;" edge="1" parent="1" source="cp-zone" target="rp-zone">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- ==================== RUNTIME PLANE ==================== -->
        <mxCell id="rp-zone" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF3E0;strokeColor=#E65100;strokeWidth=3;verticalAlign=top;fontSize=14;fontStyle=1;" vertex="1" parent="1">
