        <mxCell id="builder-label" value="OpenAI Python SDK Client Builder — _build_client()" style="text;html=1;fontSize=12;fontStyle=1;align=center;fillColor=none;strokeColor=none;fontColor=#283593;" vertex="1" parent="1">
