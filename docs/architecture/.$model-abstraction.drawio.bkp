<mxfile host="draw.io">
  <diagram name="Model Abstraction Layer" id="model-abstraction">
    <mxGraphModel dx="1400" dy="900" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1400" pageHeight="900">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <!-- Title -->
        <mxCell id="title" value="Model Abstraction Layer &amp; Multi-Model Routing" style="text;html=1;fontSize=18;fontStyle=1;align=center;verticalAlign=middle;fillColor=none;strokeColor=none;" vertex="1" parent="1">
          <mxGeometry x="300" y="10" width="800" height="30" as="geometry"/>
        </mxCell>

        <!-- ==================== OUTER BOX ==================== -->
        <mxCell id="mal-outer" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F3E5F5;strokeColor=#6A1B9A;strokeWidth=3;verticalAlign=top;" vertex="1" parent="1">
          <mxGeometry x="100" y="55" width="1200" height="680" as="geometry"/>
        </mxCell>
        <mxCell id="mal-label" value="MODEL ABSTRACTION LAYER" style="text;html=1;fontSize=14;fontStyle=1;align=center;fillColor=none;strokeColor=none;fontColor=#6A1B9A;" vertex="1" parent="1">
          <mxGeometry x="500" y="63" width="400" height="22" as="geometry"/>
        </mxCell>

        <!-- ==================== UNIFIED API ==================== -->
        <mxCell id="api-box" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E1BEE7;strokeColor=#6A1B9A;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="250" y="100" width="900" height="70" as="geometry"/>
        </mxCell>
        <mxCell id="api-label" value="OpenAI-Compatible Chat Completions API" style="text;html=1;fontSize=13;fontStyle=1;align=center;fillColor=none;strokeColor=none;fontColor=#4A148C;" vertex="1" parent="1">
          <mxGeometry x="450" y="108" width="500" height="20" as="geometry"/>
        </mxCell>
        <mxCell id="api-sub" value="Same interface for ALL providers — AsyncOpenAI / AsyncAzureOpenAI" style="text;html=1;fontSize=10;align=center;fillColor=none;strokeColor=none;fontColor=#666;" vertex="1" parent="1">
          <mxGeometry x="400" y="132" width="600" height="16" as="geometry"/>
        </mxCell>

        <!-- ==================== RESILIENCE LAYER ==================== -->
        <mxCell id="resilience-box" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FCE4EC;strokeColor=#C62828;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="250" y="200" width="900" height="120" as="geometry"/>
        </mxCell>
        <mxCell id="resilience-label" value="RESILIENCE LAYER" style="text;html=1;fontSize=12;fontStyle=1;align=center;fillColor=none;strokeColor=none;fontColor=#C62828;" vertex="1" parent="1">
          <mxGeometry x="550" y="208" width="300" height="18" as="geometry"/>
        </mxCell>

        <mxCell id="cb" value="Circuit Breaker&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;3 failures = open&lt;br&gt;60s recovery timeout&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFCDD2;strokeColor=#C62828;fontSize=11;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="290" y="240" width="180" height="60" as="geometry"/>
        </mxCell>
        <mxCell id="fallback" value="Fallback Chain&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;primary → secondary&lt;br&gt;endpoint routing&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFCDD2;strokeColor=#C62828;fontSize=11;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="510" y="240" width="180" height="60" as="geometry"/>
        </mxCell>
        <mxCell id="costcalc" value="Cost Calculator&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;token count × pricing&lt;br&gt;per-model rates&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFCDD2;strokeColor=#C62828;fontSize=11;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="730" y="240" width="180" height="60" as="geometry"/>
        </mxCell>
        <mxCell id="reasoning" value="Reasoning Detection&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;o1/o3/o4/gpt-5&lt;br&gt;auto-adjust params&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFCDD2;strokeColor=#C62828;fontSize=11;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="950" y="240" width="170" height="60" as="geometry"/>
        </mxCell>

        <!-- Arrows between resilience components -->
