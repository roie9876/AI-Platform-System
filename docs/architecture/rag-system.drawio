<mxfile host="draw.io">
  <diagram name="RAG System" id="rag-system">
    <mxGraphModel dx="1400" dy="800" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1400" pageHeight="800">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <!-- Title -->
        <mxCell id="title" value="RAG System — Retrieval-Augmented Generation" style="text;html=1;fontSize=18;fontStyle=1;align=center;verticalAlign=middle;fillColor=none;strokeColor=none;" vertex="1" parent="1">
          <mxGeometry x="300" y="10" width="800" height="30" as="geometry"/>
        </mxCell>

        <!-- ========== INGESTION PIPELINE (top) ========== -->
        <mxCell id="ingest-zone" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E3F2FD;strokeColor=#1565C0;strokeWidth=2;dashed=1;dashPattern=8 8;" vertex="1" parent="1">
          <mxGeometry x="40" y="55" width="1320" height="200" as="geometry"/>
        </mxCell>
        <mxCell id="ingest-label" value="INGESTION PIPELINE" style="text;html=1;fontSize=12;fontStyle=1;align=left;fillColor=none;strokeColor=none;fontColor=#1565C0;" vertex="1" parent="1">
          <mxGeometry x="55" y="63" width="200" height="18" as="geometry"/>
        </mxCell>

        <mxCell id="upload" value="Upload Document&lt;br&gt;or URL" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#BBDEFB;strokeColor=#1565C0;fontSize=11;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="80" y="105" width="160" height="55" as="geometry"/>
        </mxCell>
        <mxCell id="upload-types" value="PDF, DOCX, TXT, MD&lt;br&gt;Web URLs, SharePoint" style="text;html=1;fontSize=9;align=center;fillColor=none;strokeColor=none;fontColor=#666;" vertex="1" parent="1">
          <mxGeometry x="80" y="165" width="160" height="30" as="geometry"/>
        </mxCell>

        <mxCell id="parse" value="Parse &amp;&lt;br&gt;Chunk" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#BBDEFB;strokeColor=#1565C0;fontSize=11;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="320" y="105" width="140" height="55" as="geometry"/>
        </mxCell>
        <mxCell id="parse-detail" value="1000 chars / chunk&lt;br&gt;200 char overlap" style="text;html=1;fontSize=9;align=center;fillColor=none;strokeColor=none;fontColor=#666;" vertex="1" parent="1">
          <mxGeometry x="320" y="165" width="140" height="30" as="geometry"/>
        </mxCell>

        <mxCell id="embed" value="Generate&lt;br&gt;Embeddings" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E1BEE7;strokeColor=#6A1B9A;fontSize=11;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="540" y="105" width="140" height="55" as="geometry"/>
        </mxCell>
        <mxCell id="embed-detail" value="text-embedding-3-small&lt;br&gt;1536 dimensions" style="text;html=1;fontSize=9;align=center;fillColor=none;strokeColor=none;fontColor=#666;" vertex="1" parent="1">
          <mxGeometry x="540" y="165" width="140" height="30" as="geometry"/>
        </mxCell>

        <!-- Fork to two storage paths -->
        <mxCell id="store-local" value="Local Chunks&lt;br&gt;(Cosmos DB)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E8F5E9;strokeColor=#2E7D32;fontSize=11;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="780" y="85" width="170" height="55" as="geometry"/>
        </mxCell>
        <mxCell id="store-local-detail" value="document_chunks container&lt;br&gt;partition: /tenant_id" style="text;html=1;fontSize=9;align=center;fillColor=none;strokeColor=none;fontColor=#666;" vertex="1" parent="1">
          <mxGeometry x="780" y="143" width="170" height="24" as="geometry"/>
        </mxCell>
        <mxCell id="store-local-icon" value="" style="image;aspect=fixed;html=1;points=[];align=center;image=img/lib/azure2/databases/Azure_Cosmos_DB.svg;" vertex="1" parent="1">
          <mxGeometry x="945" y="90" width="40" height="40" as="geometry"/>
        </mxCell>

        <mxCell id="store-search" value="Azure AI Search&lt;br&gt;Index" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF3E0;strokeColor=#E65100;fontSize=11;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="780" y="180" width="170" height="55" as="geometry"/>
        </mxCell>
        <mxCell id="store-search-detail" value="Hybrid: vector + keyword&lt;br&gt;per-agent scoping" style="text;html=1;fontSize=9;align=center;fillColor=none;strokeColor=none;fontColor=#666;" vertex="1" parent="1">
          <mxGeometry x="955" y="185" width="160" height="24" as="geometry"/>
        </mxCell>
        <mxCell id="store-search-icon" value="" style="image;aspect=fixed;html=1;points=[];align=center;image=img/lib/azure2/app_services/Search_Services.svg;" vertex="1" parent="1">
          <mxGeometry x="1120" y="185" width="40" height="40" as="geometry"/>
        </mxCell>

        <!-- Ingestion arrows -->
        <mxCell id="a-up-parse" value="" style="edgeStyle=orthogonalEdgeStyle;strokeWidth=2;strokeColor=#1565C0;" edge="1" parent="1" source="upload" target="parse">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="a-parse-embed" value="" style="edgeStyle=orthogonalEdgeStyle;strokeWidth=2;strokeColor=#1565C0;" edge="1" parent="1" source="parse" target="embed">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="a-embed-local" value="" style="edgeStyle=orthogonalEdgeStyle;strokeWidth=2;strokeColor=#2E7D32;" edge="1" parent="1" source="embed" target="store-local">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="a-embed-search" value="" style="edgeStyle=orthogonalEdgeStyle;strokeWidth=2;strokeColor=#E65100;" edge="1" parent="1" source="embed" target="store-search">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- ========== RETRIEVAL + INJECTION (bottom) ========== -->
        <mxCell id="retrieve-zone" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF3E0;strokeColor=#E65100;strokeWidth=2;dashed=1;dashPattern=8 8;" vertex="1" parent="1">
          <mxGeometry x="40" y="300" width="1320" height="280" as="geometry"/>
        </mxCell>
        <mxCell id="retrieve-label" value="RETRIEVAL &amp; INJECTION (at execution time)" style="text;html=1;fontSize=12;fontStyle=1;align=left;fillColor=none;strokeColor=none;fontColor=#E65100;" vertex="1" parent="1">
          <mxGeometry x="55" y="308" width="350" height="18" as="geometry"/>
        </mxCell>

        <mxCell id="user-msg" value="User Message" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFE0B2;strokeColor=#E65100;fontSize=11;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="80" y="360" width="140" height="50" as="geometry"/>
        </mxCell>

        <!-- Two parallel retrieval paths -->
        <mxCell id="ret-local" value="Local Retrieval&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;rag_service.retrieve()&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E8F5E9;strokeColor=#2E7D32;fontSize=11;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="340" y="340" width="200" height="50" as="geometry"/>
        </mxCell>
        <mxCell id="ret-search" value="Azure AI Search&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;retrieve_from_azure_search()&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF3E0;strokeColor=#E65100;fontSize=11;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="340" y="410" width="200" height="50" as="geometry"/>
        </mxCell>

        <mxCell id="parallel-label" value="Executed&lt;br&gt;in parallel" style="text;html=1;fontSize=9;fontStyle=2;align=center;fillColor=none;strokeColor=none;fontColor=#666;" vertex="1" parent="1">
          <mxGeometry x="260" y="380" width="65" height="30" as="geometry"/>
        </mxCell>

        <!-- Merge -->
        <mxCell id="merge" value="Merge &amp; Rank&lt;br&gt;Chunks" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E1BEE7;strokeColor=#6A1B9A;fontSize=11;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="640" y="360" width="150" height="80" as="geometry"/>
        </mxCell>

        <!-- Context formatting -->
        <mxCell id="format" value="Format RAG&lt;br&gt;Context" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E8EAF6;strokeColor=#283593;fontSize=11;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="880" y="370" width="140" height="55" as="geometry"/>
        </mxCell>

        <!-- Prompt construction -->
        <mxCell id="prompt" value="Inject into&lt;br&gt;Agent Prompt" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#C8E6C9;strokeColor=#2E7D32;fontSize=11;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="1110" y="370" width="140" height="55" as="geometry"/>
        </mxCell>

        <!-- Retrieval arrows -->
        <mxCell id="a-msg-local" value="" style="edgeStyle=orthogonalEdgeStyle;strokeWidth=2;strokeColor=#2E7D32;" edge="1" parent="1" source="user-msg" target="ret-local">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="a-msg-search" value="" style="edgeStyle=orthogonalEdgeStyle;strokeWidth=2;strokeColor=#E65100;" edge="1" parent="1" source="user-msg" target="ret-search">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="a-local-merge" value="" style="edgeStyle=orthogonalEdgeStyle;strokeWidth=2;strokeColor=#6A1B9A;" edge="1" parent="1" source="ret-local" target="merge">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="a-search-merge" value="" style="edgeStyle=orthogonalEdgeStyle;strokeWidth=2;strokeColor=#6A1B9A;" edge="1" parent="1" source="ret-search" target="merge">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="a-merge-format" value="" style="edgeStyle=orthogonalEdgeStyle;strokeWidth=2;strokeColor=#283593;" edge="1" parent="1" source="merge" target="format">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="a-format-prompt" value="" style="edgeStyle=orthogonalEdgeStyle;strokeWidth=2;strokeColor=#2E7D32;" edge="1" parent="1" source="format" target="prompt">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Prompt structure preview -->
        <mxCell id="prompt-preview" value="{system_prompt}&lt;br&gt;+ RAG context chunks&lt;br&gt;+ user_message&lt;br&gt;→ LLM" style="text;html=1;fontSize=9;align=left;fillColor=#FFF9C4;strokeColor=#F9A825;rounded=1;spacing=6;" vertex="1" parent="1">
          <mxGeometry x="1110" y="440" width="160" height="60" as="geometry"/>
        </mxCell>

        <!-- Graceful degradation note -->
        <mxCell id="graceful" value="If RAG retrieval fails, agent still responds (without external context)" style="text;html=1;fontSize=10;align=center;fillColor=#FFCDD2;strokeColor=#C62828;rounded=1;fontStyle=2;spacing=4;" vertex="1" parent="1">
          <mxGeometry x="340" y="490" width="420" height="24" as="geometry"/>
        </mxCell>

        <!-- Connection lines from storage to retrieval -->
        <mxCell id="store-ret-local" value="" style="edgeStyle=orthogonalEdgeStyle;strokeWidth=1.5;strokeColor=#2E7D32;dashed=1;dashPattern=6 4;" edge="1" parent="1" source="store-local" target="ret-local">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="store-ret-search" value="" style="edgeStyle=orthogonalEdgeStyle;strokeWidth=1.5;strokeColor=#E65100;dashed=1;dashPattern=6 4;" edge="1" parent="1" source="store-search" target="ret-search">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
