        <mxCell id="mw1" value="1. Validate JWT&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;JWKS cache 24h&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFCDD2;strokeColor=#C62828;fontSize=10;fontStyle=1;" parent="1" vertex="1">
          <mxGeometry x="770" y="125" width="140" height="45" as="geometry" />
        </mxCell>
        <mxCell id="mw2" value="2. Verify audience&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;= ENTRA_APP_CLIENT_ID&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFCDD2;strokeColor=#C62828;fontSize=10;fontStyle=1;" parent="1" vertex="1">
          <mxGeometry x="930" y="125" width="160" height="45" as="geometry" />
        </mxCell>
        <mxCell id="mw3" value="3. Extract identity&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;oid, email, groups&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFCDD2;strokeColor=#C62828;fontSize=10;fontStyle=1;" parent="1" vertex="1">
          <mxGeometry x="1110" y="125" width="160" height="45" as="geometry" />
        </mxCell>
        <mxCell id="mw4" value="4. Resolve tenant_id&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;from X-Tenant-Id header&lt;br&gt;or &#39;tid&#39; claim&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFCDD2;strokeColor=#C62828;fontSize=10;fontStyle=1;" parent="1" vertex="1">
          <mxGeometry x="770" y="195" width="170" height="55" as="geometry" />
        </mxCell>
        <mxCell id="mw5" value="5. Check tenant status&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;cache 60s TTL&lt;br&gt;suspended → 403&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFCDD2;strokeColor=#C62828;fontSize=10;fontStyle=1;" parent="1" vertex="1">
          <mxGeometry x="970" y="195" width="170" height="55" as="geometry" />
        </mxCell>
        <mxCell id="mw6" value="6. Attach to request&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;request.state.tenant_id&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#C8E6C9;strokeColor=#2E7D32;fontSize=10;fontStyle=1;" parent="1" vertex="1">
