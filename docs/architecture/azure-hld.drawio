<mxfile host="draw.io">
  <diagram name="Azure HLD - AI Agent Platform" id="azure-hld">
    <mxGraphModel dx="1600" dy="1200" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1600" pageHeight="1200">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <!-- ==================== TITLE ==================== -->
        <mxCell id="title" value="AI Agent Platform as a Service — Azure High-Level Design" style="text;html=1;fontSize=20;fontStyle=1;align=center;verticalAlign=middle;fillColor=none;strokeColor=none;" vertex="1" parent="1">
          <mxGeometry x="300" y="8" width="1000" height="35" as="geometry"/>
        </mxCell>

        <!-- ==================== EXTERNAL USERS ==================== -->
        <mxCell id="users" value="Users / CLI / API" style="shape=mxgraph.azure.user;fillColor=#0078D4;fontColor=#333333;strokeColor=none;fontSize=11;fontStyle=1;verticalLabelPosition=bottom;verticalAlign=top;labelBackgroundColor=none;" vertex="1" parent="1">
          <mxGeometry x="478" y="55" width="44" height="50" as="geometry"/>
        </mxCell>

        <!-- ==================== IDENTITY & SECURITY ZONE ==================== -->
        <mxCell id="identity-zone" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF3E0;strokeColor=#E65100;strokeWidth=2;dashed=1;dashPattern=8 8;opacity=40;" vertex="1" parent="1">
          <mxGeometry x="1060" y="45" width="320" height="95" as="geometry"/>
        </mxCell>
        <mxCell id="identity-label" value="Identity &amp; Security" style="text;html=1;fontSize=11;fontStyle=1;align=center;fillColor=none;strokeColor=none;fontColor=#E65100;" vertex="1" parent="1">
          <mxGeometry x="1130" y="48" width="180" height="18" as="geometry"/>
        </mxCell>

        <mxCell id="entra" value="Entra ID" style="image;aspect=fixed;html=1;points=[];align=center;image=img/lib/azure2/identity/Azure_Active_Directory.svg;labelPosition=center;verticalLabelPosition=bottom;verticalAlign=top;fontSize=10;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="1095" y="68" width="45" height="45" as="geometry"/>
        </mxCell>

        <mxCell id="managed-id" value="Managed Identity" style="image;aspect=fixed;html=1;points=[];align=center;image=img/lib/azure2/identity/Managed_Identities.svg;labelPosition=center;verticalLabelPosition=bottom;verticalAlign=top;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="1280" y="68" width="45" height="45" as="geometry"/>
        </mxCell>

        <!-- ==================== EDGE / INGRESS ==================== -->
        <mxCell id="agc" value="Application Gateway&#xa;for Containers (AGC)" style="image;aspect=fixed;html=1;points=[];align=center;image=img/lib/azure2/networking/Application_Gateway_Containers.svg;labelPosition=center;verticalLabelPosition=bottom;verticalAlign=top;fontSize=10;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="478" y="175" width="45" height="45" as="geometry"/>
        </mxCell>

        <!-- ==================== ACR ==================== -->
        <mxCell id="acr" value="Container&#xa;Registry" style="image;aspect=fixed;html=1;points=[];align=center;image=img/lib/azure2/containers/Container_Registries.svg;labelPosition=center;verticalLabelPosition=bottom;verticalAlign=top;fontSize=10;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="20" y="430" width="45" height="45" as="geometry"/>
        </mxCell>

        <!-- ==================== AKS CLUSTER ==================== -->
        <mxCell id="aks-box" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F5F5F5;strokeColor=#666666;strokeWidth=3;verticalAlign=top;" vertex="1" parent="1">
          <mxGeometry x="100" y="280" width="950" height="420" as="geometry"/>
        </mxCell>

        <mxCell id="aks-label" value="AKS Cluster — stumsft-aiplatform-prod-aks" style="image;aspect=fixed;html=1;points=[];align=left;image=img/lib/azure2/containers/Kubernetes_Services.svg;labelPosition=right;verticalLabelPosition=middle;verticalAlign=middle;fontSize=13;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="115" y="286" width="28" height="28" as="geometry"/>
        </mxCell>

        <!-- ===== CONTROL PLANE ZONE ===== -->
        <mxCell id="cp-zone" value="CONTROL PLANE&#xa;(aiplatform namespace)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DAE8FC;strokeColor=#6C8EBF;strokeWidth=2;verticalAlign=top;fontSize=11;fontStyle=1;align=center;" vertex="1" parent="1">
          <mxGeometry x="125" y="322" width="230" height="155" as="geometry"/>
        </mxCell>

        <mxCell id="api-gw" value="api-gateway" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#6C8EBF;strokeWidth=2;fontSize=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="143" y="367" width="195" height="36" as="geometry"/>
        </mxCell>
        <mxCell id="api-gw-desc" value="Auth · Agent CRUD · Tenants&#xa;Marketplace · Evaluations&#xa;Observability · Policies" style="text;html=1;fontSize=9;align=center;fillColor=none;strokeColor=none;fontColor=#666666;" vertex="1" parent="1">
          <mxGeometry x="143" y="405" width="195" height="42" as="geometry"/>
        </mxCell>

        <!-- ===== RUNTIME PLANE ZONE ===== -->
        <mxCell id="rp-zone" value="RUNTIME PLANE (tenant-{slug} namespaces)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#D5E8D4;strokeColor=#82B366;strokeWidth=2;verticalAlign=top;fontSize=11;fontStyle=1;align=center;" vertex="1" parent="1">
          <mxGeometry x="380" y="322" width="640" height="155" as="geometry"/>
        </mxCell>

        <!-- Runtime pods: LEFT column = tool-exec, wf-engine | RIGHT column = agent-exec, mcp-proxy -->
        <mxCell id="tool-exec" value="tool-executor" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#82B366;strokeWidth=2;fontSize=11;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="405" y="355" width="148" height="32" as="geometry"/>
        </mxCell>
        <mxCell id="te-desc" value="Tool Registry · RAG · Data Sources" style="text;html=1;fontSize=8;align=center;fillColor=none;strokeColor=none;fontColor=#666666;" vertex="1" parent="1">
          <mxGeometry x="405" y="389" width="148" height="16" as="geometry"/>
        </mxCell>

        <mxCell id="agent-exec" value="agent-executor" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#82B366;strokeWidth=2;fontSize=11;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="845" y="355" width="148" height="32" as="geometry"/>
        </mxCell>
        <mxCell id="ae-desc" value="ReAct Loop · Chat SSE · Threads" style="text;html=1;fontSize=8;align=center;fillColor=none;strokeColor=none;fontColor=#666666;" vertex="1" parent="1">
          <mxGeometry x="845" y="389" width="148" height="16" as="geometry"/>
        </mxCell>

        <mxCell id="wf-engine" value="workflow-engine" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#82B366;strokeWidth=2;fontSize=11;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="405" y="425" width="148" height="32" as="geometry"/>
        </mxCell>
        <mxCell id="wf-desc" value="DAG Orchestration · Multi-Agent" style="text;html=1;fontSize=8;align=center;fillColor=none;strokeColor=none;fontColor=#666666;" vertex="1" parent="1">
          <mxGeometry x="405" y="459" width="148" height="16" as="geometry"/>
        </mxCell>

        <mxCell id="mcp-proxy" value="mcp-proxy" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#82B366;strokeWidth=2;fontSize=11;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="845" y="425" width="148" height="32" as="geometry"/>
        </mxCell>
        <mxCell id="mcp-desc" value="Server Discovery · Protocol Bridge" style="text;html=1;fontSize=8;align=center;fillColor=none;strokeColor=none;fontColor=#666666;" vertex="1" parent="1">
          <mxGeometry x="845" y="459" width="148" height="16" as="geometry"/>
        </mxCell>

        <!-- Internal flow note (avoids drawing edges that cross) -->
        <mxCell id="internal-note" value="AE ↔ TE · AE ↔ MCP · WF → AE" style="text;html=1;fontSize=9;align=center;fillColor=none;strokeColor=none;fontColor=#82B366;fontStyle=2;" vertex="1" parent="1">
          <mxGeometry x="560" y="410" width="200" height="16" as="geometry"/>
        </mxCell>

        <!-- ===== FRONTEND ZONE (bottom of AKS — no blocking) ===== -->
        <mxCell id="fe-zone" value="PRESENTATION" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF2CC;strokeColor=#D6B656;strokeWidth=2;verticalAlign=top;fontSize=11;fontStyle=1;align=center;" vertex="1" parent="1">
          <mxGeometry x="125" y="500" width="900" height="170" as="geometry"/>
        </mxCell>

        <mxCell id="frontend" value="frontend (Next.js 15)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#D6B656;strokeWidth=2;fontSize=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="380" y="540" width="220" height="36" as="geometry"/>
        </mxCell>
        <mxCell id="fe-desc" value="React 19 · MSAL Auth · Workflow Builder · Dashboards" style="text;html=1;fontSize=9;align=center;fillColor=none;strokeColor=none;fontColor=#666666;" vertex="1" parent="1">
          <mxGeometry x="340" y="578" width="300" height="18" as="geometry"/>
        </mxCell>

        <!-- ==================== EXTERNAL AI SERVICES (right of AKS — clear path) ==================== -->
        <mxCell id="aoai" value="Azure OpenAI" style="image;aspect=fixed;html=1;points=[];align=center;image=img/lib/azure2/ai_machine_learning/Azure_OpenAI.svg;labelPosition=right;verticalLabelPosition=middle;verticalAlign=middle;fontSize=11;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="1150" y="348" width="50" height="50" as="geometry"/>
        </mxCell>

        <mxCell id="ext-mcp" value="External MCP Servers&#xa;(Jira, GitHub, Slack)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E1D5E7;strokeColor=#9673A6;strokeWidth=2;fontSize=10;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="1130" y="425" width="140" height="50" as="geometry"/>
        </mxCell>

        <!-- ==================== DATA SERVICES ZONE ==================== -->
        <mxCell id="data-zone" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E8F5E9;strokeColor=#43A047;strokeWidth=2;dashed=1;dashPattern=8 8;opacity=50;" vertex="1" parent="1">
          <mxGeometry x="100" y="740" width="950" height="120" as="geometry"/>
        </mxCell>
        <mxCell id="data-label" value="DATA &amp; PLATFORM SERVICES" style="text;html=1;fontSize=11;fontStyle=1;align=center;fillColor=none;strokeColor=none;fontColor=#2E7D32;" vertex="1" parent="1">
          <mxGeometry x="370" y="743" width="360" height="18" as="geometry"/>
        </mxCell>

        <mxCell id="cosmos" value="Cosmos DB&#xa;(35 containers)" style="image;aspect=fixed;html=1;points=[];align=center;image=img/lib/azure2/databases/Azure_Cosmos_DB.svg;labelPosition=center;verticalLabelPosition=bottom;verticalAlign=top;fontSize=10;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="160" y="770" width="45" height="45" as="geometry"/>
        </mxCell>

        <mxCell id="keyvault" value="Key Vault" style="image;aspect=fixed;html=1;points=[];align=center;image=img/lib/azure2/security/Key_Vaults.svg;labelPosition=center;verticalLabelPosition=bottom;verticalAlign=top;fontSize=10;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="370" y="770" width="45" height="45" as="geometry"/>
        </mxCell>

        <mxCell id="ai-search" value="AI Search" style="image;aspect=fixed;html=1;points=[];align=center;image=img/lib/azure2/app_services/Search_Services.svg;labelPosition=center;verticalLabelPosition=bottom;verticalAlign=top;fontSize=10;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="580" y="770" width="45" height="45" as="geometry"/>
        </mxCell>

        <mxCell id="servicebus" value="Service Bus" style="image;aspect=fixed;html=1;points=[];align=center;image=img/lib/azure2/integration/Service_Bus.svg;labelPosition=center;verticalLabelPosition=bottom;verticalAlign=top;fontSize=10;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="790" y="770" width="45" height="45" as="geometry"/>
        </mxCell>

        <!-- ==================== OBSERVABILITY ZONE ==================== -->
        <mxCell id="obs-zone" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E3F2FD;strokeColor=#1565C0;strokeWidth=2;dashed=1;dashPattern=8 8;opacity=50;" vertex="1" parent="1">
          <mxGeometry x="100" y="900" width="950" height="110" as="geometry"/>
        </mxCell>
        <mxCell id="obs-label" value="OBSERVABILITY" style="text;html=1;fontSize=11;fontStyle=1;align=center;fillColor=none;strokeColor=none;fontColor=#1565C0;" vertex="1" parent="1">
          <mxGeometry x="420" y="903" width="260" height="18" as="geometry"/>
        </mxCell>

        <mxCell id="appinsights" value="App Insights" style="image;aspect=fixed;html=1;points=[];align=center;image=img/lib/azure2/devops/Application_Insights.svg;labelPosition=center;verticalLabelPosition=bottom;verticalAlign=top;fontSize=10;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="195" y="930" width="45" height="45" as="geometry"/>
        </mxCell>

        <mxCell id="loganalytics" value="Log Analytics" style="image;aspect=fixed;html=1;points=[];align=center;image=img/lib/azure2/analytics/Log_Analytics_Workspaces.svg;labelPosition=center;verticalLabelPosition=bottom;verticalAlign=top;fontSize=10;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="440" y="930" width="45" height="45" as="geometry"/>
        </mxCell>

        <mxCell id="monitor" value="Azure Monitor" style="image;aspect=fixed;html=1;points=[];align=center;image=img/lib/azure2/management_governance/Monitor.svg;labelPosition=center;verticalLabelPosition=bottom;verticalAlign=top;fontSize=10;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="685" y="930" width="45" height="45" as="geometry"/>
        </mxCell>

        <mxCell id="alerts" value="Alerts" style="image;aspect=fixed;html=1;points=[];align=center;image=img/lib/azure2/management_governance/Alerts.svg;labelPosition=center;verticalLabelPosition=bottom;verticalAlign=top;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="910" y="930" width="45" height="45" as="geometry"/>
        </mxCell>

        <!-- ==================== EDGES ==================== -->

        <!-- Users → AGC (HTTPS) — vertical, clean -->
        <mxCell id="e-users-agc" value="HTTPS" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=2;strokeColor=#0078D4;fontSize=10;fontStyle=1;" edge="1" source="users" target="agc" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Users → Entra (OAuth2/PKCE) — horizontal right, nothing in path -->
        <mxCell id="e-users-entra" value="OAuth2 / PKCE" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=1;strokeColor=#E65100;dashed=1;dashPattern=8 4;fontSize=9;fontColor=#E65100;" edge="1" source="users" target="entra" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- AGC → AKS (path-based routing into cluster) — vertical down, clean -->
        <mxCell id="e-agc-aks" value="/api/* → backend&#xa;/ → frontend" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=2;strokeColor=#0078D4;fontSize=9;labelPosition=right;verticalLabelPosition=middle;verticalAlign=middle;align=left;" edge="1" source="agc" target="aks-box" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Agent Executor → Azure OpenAI (LLM) — horizontal right, CLEAR PATH (nothing between AE right edge and AOAI) -->
        <mxCell id="e-ae-aoai" value="LLM calls" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=2;strokeColor=#FF6D00;fontSize=10;fontStyle=1;" edge="1" source="agent-exec" target="aoai" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- MCP Proxy → External MCP — horizontal right, CLEAR PATH -->
        <mxCell id="e-mcp-ext" value="MCP protocol" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=1;strokeColor=#9673A6;fontSize=9;" edge="1" source="mcp-proxy" target="ext-mcp" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- ACR → AKS (image pull) — horizontal right, clean -->
        <mxCell id="e-acr-aks" value="image pull" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=1;strokeColor=#666666;dashed=1;dashPattern=8 4;fontSize=9;" edge="1" source="acr" target="aks-box" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- AKS → Data Services (zone-level edges — go straight down from AKS bottom) -->
        <mxCell id="e-aks-cosmos" value="config + state" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=2;strokeColor=#43A047;fontSize=9;exitX=0.18;exitY=1;exitDx=0;exitDy=0;" edge="1" source="aks-box" target="cosmos" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell id="e-aks-kv" value="secrets" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=1;strokeColor=#43A047;dashed=1;fontSize=9;exitX=0.35;exitY=1;exitDx=0;exitDy=0;" edge="1" source="aks-box" target="keyvault" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell id="e-aks-search" value="RAG" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=2;strokeColor=#43A047;fontSize=9;exitX=0.55;exitY=1;exitDx=0;exitDy=0;" edge="1" source="aks-box" target="ai-search" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell id="e-aks-sb" value="async / KEDA" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=1;strokeColor=#43A047;dashed=1;fontSize=9;exitX=0.78;exitY=1;exitDx=0;exitDy=0;" edge="1" source="aks-box" target="servicebus" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- AKS → Managed Identity (workload identity) — from top-right of AKS -->
        <mxCell id="e-aks-mid" value="Workload Identity" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=1;strokeColor=#E65100;dashed=1;dashPattern=8 4;fontSize=9;fontColor=#E65100;exitX=1;exitY=0;exitDx=0;exitDy=0;" edge="1" source="aks-box" target="managed-id" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- AKS → App Insights (telemetry) — down through data zone to obs -->
        <mxCell id="e-aks-obs" value="OpenTelemetry" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=1;strokeColor=#1565C0;dashed=1;dashPattern=4 4;fontSize=9;fontColor=#1565C0;exitX=0.12;exitY=1;exitDx=0;exitDy=0;" edge="1" source="aks-box" target="appinsights" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Observability chain: App Insights → Log Analytics → Monitor → Alerts -->
        <mxCell id="e-ai-la" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=1;strokeColor=#1565C0;" edge="1" source="appinsights" target="loganalytics" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell id="e-la-mon" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=1;strokeColor=#1565C0;" edge="1" source="loganalytics" target="monitor" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell id="e-mon-alerts" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=1;strokeColor=#1565C0;" edge="1" source="monitor" target="alerts" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- ==================== LEGEND ==================== -->
        <mxCell id="legend-box" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#333333;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="1120" y="560" width="310" height="145" as="geometry"/>
        </mxCell>
        <mxCell id="legend-title" value="Legend" style="text;html=1;fontSize=12;fontStyle=1;align=left;fillColor=none;strokeColor=none;" vertex="1" parent="1">
          <mxGeometry x="1135" y="565" width="80" height="18" as="geometry"/>
        </mxCell>
        <mxCell id="leg1" value="" style="endArrow=classic;strokeWidth=2;strokeColor=#0078D4;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry"><mxPoint x="1140" y="598" as="sourcePoint"/><mxPoint x="1195" y="598" as="targetPoint"/></mxGeometry>
        </mxCell>
        <mxCell id="leg1-t" value="HTTPS request flow" style="text;html=1;fontSize=9;align=left;fillColor=none;strokeColor=none;" vertex="1" parent="1">
          <mxGeometry x="1205" y="589" width="180" height="18" as="geometry"/>
        </mxCell>
        <mxCell id="leg2" value="" style="endArrow=classic;strokeWidth=2;strokeColor=#FF6D00;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry"><mxPoint x="1140" y="620" as="sourcePoint"/><mxPoint x="1195" y="620" as="targetPoint"/></mxGeometry>
        </mxCell>
        <mxCell id="leg2-t" value="LLM API calls" style="text;html=1;fontSize=9;align=left;fillColor=none;strokeColor=none;" vertex="1" parent="1">
          <mxGeometry x="1205" y="611" width="180" height="18" as="geometry"/>
        </mxCell>
        <mxCell id="leg3" value="" style="endArrow=classic;strokeWidth=2;strokeColor=#43A047;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry"><mxPoint x="1140" y="642" as="sourcePoint"/><mxPoint x="1195" y="642" as="targetPoint"/></mxGeometry>
        </mxCell>
        <mxCell id="leg3-t" value="Data service connections" style="text;html=1;fontSize=9;align=left;fillColor=none;strokeColor=none;" vertex="1" parent="1">
          <mxGeometry x="1205" y="633" width="180" height="18" as="geometry"/>
        </mxCell>
        <mxCell id="leg4" value="" style="endArrow=classic;strokeWidth=1;strokeColor=#E65100;dashed=1;dashPattern=8 4;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry"><mxPoint x="1140" y="664" as="sourcePoint"/><mxPoint x="1195" y="664" as="targetPoint"/></mxGeometry>
        </mxCell>
        <mxCell id="leg4-t" value="Identity / auth flow" style="text;html=1;fontSize=9;align=left;fillColor=none;strokeColor=none;" vertex="1" parent="1">
          <mxGeometry x="1205" y="655" width="180" height="18" as="geometry"/>
        </mxCell>
        <mxCell id="leg5" value="" style="endArrow=classic;strokeWidth=1;strokeColor=#1565C0;dashed=1;dashPattern=4 4;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry"><mxPoint x="1140" y="686" as="sourcePoint"/><mxPoint x="1195" y="686" as="targetPoint"/></mxGeometry>
        </mxCell>
        <mxCell id="leg5-t" value="Telemetry / observability" style="text;html=1;fontSize=9;align=left;fillColor=none;strokeColor=none;" vertex="1" parent="1">
          <mxGeometry x="1205" y="677" width="180" height="18" as="geometry"/>
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
