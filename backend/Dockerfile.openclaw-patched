FROM ghcr.io/openclaw/openclaw:latest

# ── Patch #1: Fix AwaitingInitialSync stall ───────────────────────────
# OpenClaw's compiled dist/ sets shouldSyncHistoryMessage: () => true,
# which causes Baileys v7 to enter AwaitingInitialSync mode for 120+
# seconds on connect. During this time, ALL real-time message events
# (type: "notify") are blocked. Only buffered "append" events arrive.
#
# Fix: Change shouldSyncHistoryMessage from () => true to () => false
# in the dist file. The TS source only has syncFullHistory: false
# (no explicit shouldSyncHistoryMessage) so no TS patch needed.
#
# ── Patch #2: Fix zombie socket leak ─────────────────────────────
USER root
RUN \
    # ── Patch #1: shouldSyncHistoryMessage: () => false ──────────────
    for JS_FILE in $(grep -rl 'shouldSyncHistoryMessage: () => true' /app/dist --include='*.js' 2>/dev/null || true); do \
        sed -i 's/shouldSyncHistoryMessage: () => true/shouldSyncHistoryMessage: () => false/' "$JS_FILE" && \
        echo "Patch #1 (dist): $JS_FILE — shouldSyncHistoryMessage: () => false"; \
    done && \
    # ── Patch #2: Fix zombie socket leak ─────────────────────────────
    # closeInboundMonitorSocket() calls sock.ws?.close?.() instead of
    # sock.end(). This leaves zombie sockets with leaked event listeners
    # and stale signal-key stores.
    #
    # Fix: Replace sock.ws?.close?.() with sock.end?.() in the
    # closeInboundMonitorSocket function.
    # The function is multi-line in login-*.js (not in session-*.js).
    LOGIN_FILE=$(grep -rl 'closeInboundMonitorSocket' /app/dist --include='*.js' | head -1) && \
    if [ -n "$LOGIN_FILE" ]; then \
        sed -i 's/sock\.ws?\.close?\.();/sock.end?.();/' "$LOGIN_FILE" && \
        echo "Patch #2 (dist) applied to $LOGIN_FILE: sock.end() instead of sock.ws?.close?()"; \
    else \
        echo "Patch #2 (dist) skipped: closeInboundMonitorSocket not found"; \
    fi && \
    # Also patch TS sources for Patch #2
    for TS_FILE in $(grep -rl 'sock\.ws?\.close' /app/extensions --include='*.ts' 2>/dev/null || true); do \
        sed -i 's/sock\.ws?\.close?\.();/sock.end?.();/' "$TS_FILE" && \
        echo "Patch #2 (ts): $TS_FILE — sock.end() instead of sock.ws?.close?()"; \
    done && \
    # ── Patch #3: Disable stale creds backup restore ─────────────────
    # maybeRestoreCredsFromBackup() restores creds.json from .bak on
    # every pod restart if the current creds.json is corrupted. This
    # often restores STALE creds from before a QR re-link, causing
    # registered: false and zero inbound messages.
    #
    # Fix: Remove ALL call sites of maybeRestoreCredsFromBackup().
    # The function definition return; patch didn't work reliably,
    # so we nuke every invocation instead.
    for CALL_FILE in $(grep -rl 'maybeRestoreCredsFromBackup' /app/dist --include='*.js'); do \
        BEFORE=$(grep -c 'maybeRestoreCredsFromBackup' "$CALL_FILE") && \
        sed -i 's/maybeRestoreCredsFromBackup(resolvedAuthDir);//g' "$CALL_FILE" && \
        sed -i 's/maybeRestoreCredsFromBackup(resolvedAuthDir)//g' "$CALL_FILE" && \
        sed -i 's/maybeRestoreCredsFromBackup(authDir);//g' "$CALL_FILE" && \
        sed -i 's/maybeRestoreCredsFromBackup(authDir)//g' "$CALL_FILE" && \
        AFTER=$(grep -c 'maybeRestoreCredsFromBackup' "$CALL_FILE" || true) && \
        echo "Patch #3 (dist): $CALL_FILE — removed $((BEFORE - AFTER)) call(s) ($AFTER remaining refs)"; \
    done && \
    # ALSO patch TypeScript sources — the WhatsApp extension runs from
    # /app/extensions/whatsapp/src/ at runtime, NOT from dist/!
    for TS_FILE in $(grep -rl 'maybeRestoreCredsFromBackup' /app/extensions --include='*.ts' 2>/dev/null || true); do \
        BEFORE=$(grep -c 'maybeRestoreCredsFromBackup' "$TS_FILE") && \
        sed -i 's/maybeRestoreCredsFromBackup(resolvedAuthDir);//g' "$TS_FILE" && \
        sed -i 's/maybeRestoreCredsFromBackup(resolvedAuthDir)//g' "$TS_FILE" && \
        sed -i 's/maybeRestoreCredsFromBackup(authDir);//g' "$TS_FILE" && \
        sed -i 's/maybeRestoreCredsFromBackup(authDir)//g' "$TS_FILE" && \
        AFTER=$(grep -c 'maybeRestoreCredsFromBackup' "$TS_FILE" || true) && \
        echo "Patch #3 (ts): $TS_FILE — removed $((BEFORE - AFTER)) call(s) ($AFTER remaining refs)"; \
    done && \
    # ── Patch #4 (CRITICAL): Fix message delivery — markOnlineOnConnect ──
    # OpenClaw sets markOnlineOnConnect: false, which tells WhatsApp this
    # linked device is "offline". WhatsApp does NOT deliver messages to
    # offline linked devices — only presence/typing events arrive.
    # This is the ROOT CAUSE of zero inbound messages.
    #
    # Fix: Change markOnlineOnConnect from false to true in both dist/ and TS.
    for JS_FILE in $(grep -rl 'markOnlineOnConnect: false' /app/dist --include='*.js' 2>/dev/null || true); do \
        sed -i 's/markOnlineOnConnect: false/markOnlineOnConnect: true/' "$JS_FILE" && \
        echo "Patch #4 (dist): $JS_FILE — markOnlineOnConnect: true"; \
    done && \
    for TS_FILE in $(grep -rl 'markOnlineOnConnect: false' /app/extensions --include='*.ts' 2>/dev/null || true); do \
        sed -i 's/markOnlineOnConnect: false/markOnlineOnConnect: true/' "$TS_FILE" && \
        echo "Patch #4 (ts): $TS_FILE — markOnlineOnConnect: true"; \
    done && \
    # ── Patch #5: Include memory-slot plugins in startup plugin list ──
    # resolveGatewayStartupPluginIds filters out plugins with
    # hasRuntimeContractSurface (like memory-core, kind=memory) because
    # isGatewayStartupSidecar returns false for them.  This means
    # memory-core never loads, its register() never runs, and dreaming
    # (cron-based memory consolidation) never activates.
    #
    # Fix: After the sidecar filter, add a check for activated
    # runtime-contract plugins so memory-core is included.
    # We replace the original filter predicate to also return true
    # for plugins selected via the memory slot.
    CHANNEL_IDS_FILE=$(find /app/dist -name 'channel-plugin-ids-*.js' | head -1) && \
    if [ -n "$CHANNEL_IDS_FILE" ]; then \
        sed -i 's/if (!isGatewayStartupSidecar(plugin)) return false;/if (!isGatewayStartupSidecar(plugin)) { const _actState = resolveEffectivePluginActivationState({ id: plugin.id, origin: plugin.origin, config: pluginsConfig, rootConfig: params.config, enabledByDefault: plugin.enabledByDefault, activationSource }); if (_actState.activated) return true; return false; }/' "$CHANNEL_IDS_FILE" && \
        echo "Patch #5 (dist): $CHANNEL_IDS_FILE — memory-slot plugins included in startup"; \
    else \
        echo "Patch #5 (dist) skipped: channel-plugin-ids file not found"; \
    fi && \
    # ── Patch #6: Preserve plugin-registered hooks at startup ─────────
    # startGatewaySidecars() calls clearInternalHooks() right before
    # loadInternalHooks(), wiping ALL hooks — including those registered
    # by plugins (e.g. memory-core's gateway:startup hook for dreaming).
    # Plugins register hooks via registerInternalHook() during
    # loadOpenClawPlugins(), which runs BEFORE startGatewaySidecars().
    #
    # Fix: Remove the clearInternalHooks() call so plugin hooks survive
    # into the triggerInternalHook("gateway:startup") call.
    SERVER_FILE=$(grep -rl 'clearInternalHooks();' /app/dist --include='*.js' | head -1) && \
    if [ -n "$SERVER_FILE" ]; then \
        sed -i 's/clearInternalHooks();//' "$SERVER_FILE" && \
        echo "Patch #6 (dist): $SERVER_FILE — removed clearInternalHooks() to preserve plugin hooks"; \
    else \
        echo "Patch #6 (dist) skipped: server file not found"; \
    fi

# ── Patch #7: Suppress non-fatal "Agent listener" crash ──────────────
# pi-agent-core has a bug where a subprocess stdout event fires after
# the agent run has ended, throwing "Agent listener invoked outside
# active run". OpenClaw's unhandled rejection handler treats ALL
# unknown errors as fatal (process.exit(1)).
#
# Fix: Patch isTransientUnhandledRejectionError() to also return true
# for "Agent listener invoked outside active run" errors — they're
# harmless late callbacks, not real failures.
RUN UNHANDLED_FILE=$(find /app/dist -maxdepth 1 -name 'unhandled-rejections-*.js' | head -1) && \
    if [ -n "$UNHANDLED_FILE" ]; then \
        sed -i 's/return isTransientNetworkError(err) || isTransientSqliteError(err);/return isTransientNetworkError(err) || isTransientSqliteError(err) || (err \&\& typeof err === "object" \&\& typeof err.message === "string" \&\& err.message.includes("Agent listener invoked outside active run"));/' "$UNHANDLED_FILE" && \
        echo "Patch #7 (dist): $UNHANDLED_FILE — Agent listener crash suppressed"; \
    else \
        echo "Patch #7 (dist) skipped: unhandled-rejections file not found"; \
    fi

# ── MCP HTTP Bridge: stdio → HTTP transport adapter ──────────────────
# OpenClaw's acpx plugin only supports stdio-based MCP servers.
# This bridge script translates stdio MCP to HTTP, allowing our
# platform-tools HTTP MCP server to be used by agents.
COPY mcp-http-bridge.mjs /app/mcp-http-bridge.mjs

# ── Platform Tools Plugin: registers MCP tools as native OpenClaw tools ──
# This plugin bridges our HTTP MCP platform-tools server into the
# OpenClaw native tool system, so Azure OpenAI agents can use memory
# and config tools without requiring the acpx (Claude) backend.
COPY openclaw-plugin-platform-tools/ /app/extensions/platform-tools/

# Switch back to the openclaw user
USER 1000
